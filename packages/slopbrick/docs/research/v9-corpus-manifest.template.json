  "v8_corpus_avoidance": "These repos were NOT in the v7 or v8 corpus (per the methodology paper's cross-corpus contamination guard). Verify with grep before including.",

  "build_process": [
    "1. Copy this file to corpus-manifest.local.json (gitignored)",
    "2. For each repo, run: git fetch --unshallow && git checkout <ref>",
    "3. Compute the filelist: find <repo> -name '*.java' -size -10M | sort > <arm>.txt",
    "4. Run: slopbrick scan --workspace <repo> --format json > <repo>.json",
    "5. Concatenate per-arm: jq -s '.' <repo>.json > v9-java-<neg|pos>.json",
    "6. Compute v9 calibration: see scripts/compute-v9-calibration.py (TBD)",
    "7. Update signal-strength.json with v9 verdict, _v9Verdict, _v9Lift, _v9Recall, _v9FpRate, _v9Precision"
  ],

  "success_criteria": {
    "files_neg": "≥ 30000",
    "files_pos": "≥ 25000",
    "rules_measurable": "≥ 6 (the 6 DORMANT Java rules)",
    "rules_promoted": "≥ 1 (at least one Java rule becomes USEFUL on v9)"
  }
}
