  "_comment": "v9 corpus manifest — Java arm. The .template.json is committed; the operator copies this to corpus-manifest.local.json and fills in the local_clone_path for each repo (per the .gitignore rule, .local.json is never committed). See v9-plan-2026-07-02-update.md for the corpus build process.",
  "version": "v9.0-java-draft",
  "build_date": "2026-07-02",
  "methodology_reference": "packages/slopbrick/docs/research/methodology-minimum-sample-size.md",
  "minimum_sample_size": 10000,
  "minimum_total_fires": 10,

  "arm": "java",
  "files_target": {"neg": 30000, "pos": 25000},
