{
  "name": "slopbrick",
  "version": "0.45.0",
  "description": "Local scanner for visual, implementation, security, and repository-coherence problems amplified by AI coding. The v0.45.0 candidate is unreleased; current corpus admission and calibration evidence remain gated.",
  "type": "module",
  "bin": {
    "slopbrick": "bin/slopbrick.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "!dist/**/*.map"
  ],
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "generate:rules": "node --import tsx scripts/generate-rule-registry.ts && node --import tsx scripts/generate-rule-catalog.ts",
    "generate:rules:catalog": "node --import tsx scripts/generate-rule-catalog.ts",
    "generate:language-matrix": "node --import tsx scripts/generate-language-support-matrix.ts",
    "generate:mcp-docs": "node --import tsx scripts/generate-mcp-docs.ts",
    "bench:scan": "node --import tsx scripts/bench-scan.ts",
    "prebuild": "pnpm --filter @usebrick/engine build",
    "build": "pnpm --filter @usebrick/engine build && pnpm generate:rules && tsup",
    "test": "pnpm generate:rules && tsup && vitest run",
    "test:capabilities": "node scripts/test-capabilities.mjs",
    "test:pack-matrix": "node scripts/test-packed-runtime-matrix.mjs",
    "test:watch": "vitest",
    "test:coverage": "pnpm generate:rules && vitest run --coverage",
    "test:perf": "node --import tsx tests/perf/large-codebase.ts",
    "generate-perf-fixtures": "node --import tsx scripts/generate-perf-fixtures.ts",
    "drift:collect": "node --import tsx scripts/collect-drift-signals.ts",
    "drift:compute": "node --import tsx scripts/compute-drift-calibration.ts",
    "cal:corpus:validate": "node dist/calibration/v103/cli.cjs corpus:validate",
    "cal:corpus:v1-smoke": "node --import tsx scripts/cal/run-corpus-v1-smoke.ts",
    "cal:corpus:v1-holdout": "node --import tsx scripts/cal/run-corpus-v1-holdout.ts",
    "cal:corpus:v1-decisions": "node --import tsx scripts/cal/run-corpus-v1-decisions.ts",
    "cal:materialize": "node dist/calibration/v103/cli.cjs cal:materialize",
    "cal:select": "node dist/calibration/v103/cli.cjs select",
    "cal:init": "node dist/calibration/v103/cli.cjs run:init",
    "cal:verify": "node dist/calibration/v103/cli.cjs verify",
    "cal:scan": "node dist/calibration/v103/cli.cjs scan",
    "cal:report": "node dist/calibration/v103/cli.cjs cal:report",
    "cal:admission": "node dist/calibration/v103/admission.cjs",
    "cal:admission:smoke-input": "node dist/calibration/v103/admission.cjs admission:smoke-input",
    "cal:admission:genesis": "node --import tsx scripts/cal/build-v103-genesis.ts",
    "cal:evidence": "node dist/calibration/v103/admission.cjs",
    "typecheck": "tsc --noEmit",
    "prepack": "node scripts/prepack-guard.mjs",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build && pnpm prepack",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@swc/core": "^1.10.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "globby": "^14.0.0",
    "minimatch": "^9.0.5",
    "pgsql-parser": "^17.9.15",
    "tree-sitter": "^0.22.4",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-swift": "^0.7.1",
    "yauzl": "3.4.0"
  },
  "//_usebrick_note": "@usebrick/core and @usebrick/engine are private workspace packages. They are listed in devDependencies to keep pnpm-lock.yaml in sync; tsup.config.ts → noExternal bundles them into dist/; the prepack-guard.mjs allowlist includes both. Neither ends up in the published tarball's runtime deps. See https://github.com/usebrick/platform/blob/main/docs/repository-structure.md",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/yauzl": "3.4.0",
    "@types/yazl": "3.3.1",
    "@usebrick/core": "workspace:^0.3.0",
    "@usebrick/engine": "workspace:^",
    "@vitest/coverage-v8": "3.2.7",
    "fast-check": "^4.8.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "3.2.7",
    "yazl": "3.3.1"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "keywords": [
    "ai-coding-agents",
    "claude-code",
    "cursor",
    "copilot",
    "aider",
    "mcp",
    "model-context-protocol",
    "repository-constitution",
    "repository-memory",
    "drift-detection",
    "pattern-fragmentation",
    "coherence",
    "code-quality",
    "linter",
    "static-analysis",
    "react",
    "vue",
    "svelte",
    "typescript",
    "python",
    "go",
    "swift",
    "kotlin",
    "rust",
    "wcag",
    "ai-slop",
    "ai-debt",
    "pre-commit",
    "ci",
    "prevention"
  ],
  "author": "usebrick.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usebrick/platform.git"
  },
  "bugs": {
    "url": "https://github.com/usebrick/platform/issues"
  },
  "homepage": "https://usebrick.dev"
}
