#!/usr/bin/env bash
# slopbrick pre-push hook — installed via:
#   ln -s ../../packages/slopbrick/scripts/pre-push .git/hooks/pre-push
#
# Runs the same serialized recursive quality gates as
# .github/workflows/publish.yml, plus its generated-registry checks, so a
# green push does not skip a private workspace package or the release gate.
#
# To bypass in an emergency:
#   git push --no-verify

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Skip if this is the .kimi-code sandbox or another non-publish path
# (e.g. pushing a docs-only commit). The script runs only when the
# push target is the canonical publish branch.
PUBLISH_BRANCHES=("main")
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
IS_PUBLISH_BRANCH=false
for b in "${PUBLISH_BRANCHES[@]}"; do
  if [[ "$CURRENT_BRANCH" == "$b" ]]; then
    IS_PUBLISH_BRANCH=true
    break
  fi
done

if [[ "$IS_PUBLISH_BRANCH" != "true" ]]; then
  echo "[pre-push] branch '$CURRENT_BRANCH' is not a publish branch; skipping full gate."
  echo "[pre-push] (this hook runs the full gate on: ${PUBLISH_BRANCHES[*]})"
  exit 0
fi

echo "[pre-push] running recursive release quality gates on branch '$CURRENT_BRANCH'..."
echo "[pre-push] (matches .github/workflows/publish.yml 'Run release quality gates' step)"
echo

# Keep workspace execution serial: SlopBrick's subprocess-heavy suite is the
# RAM-sensitive step, and the publish workflow uses the same bound.
PNPM=(corepack pnpm --workspace-concurrency=1)

# Step 1: every workspace typecheck (fast — fails before spending minutes on
# tests/builds).
echo "[pre-push] 1/5: recursive typecheck"
"${PNPM[@]}" -r typecheck

# Step 2: full test suite (matches what publish.yml runs).
# This is the step that catches what scoped local runs miss.
# Bypassed only if SKIP_PRE_PUSH_TESTS=1 (e.g. for an emergency docs
# commit that is not in any publish path).
if [[ "${SKIP_PRE_PUSH_TESTS:-}" != "1" ]]; then
  echo
  echo "[pre-push] 2/5: recursive test (serialized; SlopBrick worker budget = 1)"
  SLOPBRICK_VITEST_WORKERS=1 "${PNPM[@]}" -r test
else
  echo "[pre-push] 2/5: SKIPPED (SKIP_PRE_PUSH_TESTS=1)"
fi

# Step 3: every workspace build (the codegen freshness guard is intentionally
# part of this gate).
echo
echo "[pre-push] 3/5: recursive build"
"${PNPM[@]}" -r build

# Step 4: generated registry and language support drift checks.
echo
echo "[pre-push] 4/5: generated registry/language checks"
"${PNPM[@]}" --filter slopbrick exec tsx scripts/generate-rule-registry.ts --check
"${PNPM[@]}" --filter slopbrick exec tsx scripts/generate-language-support-matrix.ts --check

# Step 5 is the successful completion message; keep the numbering explicit so
# logs are easy to compare with publish.yml.
echo
echo "[pre-push] 5/5: release gate summary"

echo
echo "[pre-push] ✅ all recursive gates green. Pushing to $CURRENT_BRANCH."
