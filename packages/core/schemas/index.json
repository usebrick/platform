{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repository Memory — Schema Index",
  "description": "Pointer to the four canonical schemas that define the usebrick.dev Repository Memory Platform. Every tool in the platform — slopbrick, stackpick, gir, the MCP server, future CI integrations — reads and writes data matching these schemas.",
  "schemas": {
    "inventory": {
      "$id": "https://usebrick.dev/schemas/inventory.schema.json",
      "file": "inventory.schema.json",
      "description": "Detected pattern inventory + component fingerprints.",
      "producedBy": ["slopbrick scan"],
      "consumedBy": ["slopbrick", "stackpick", "gir", "mcp"]
    },
    "constitution": {
      "$id": "https://usebrick.dev/schemas/constitution.schema.json",
      "file": "constitution.schema.json",
      "description": "Declared project constitution (allow-list + deny-list).",
      "producedBy": ["slopbrick scan (auto-detect from slopbrick.config.mjs)"],
      "consumedBy": ["slopbrick drift", "stackpick", "gir", "mcp"]
    },
    "memory": {
      "$id": "https://usebrick.dev/schemas/memory.schema.json",
      "file": "memory.schema.json",
      "description": "Agent-readable markdown summary (rendered from inventory + constitution).",
      "producedBy": ["slopbrick scan (auto-renders to .slopbrick/memory.md)"],
      "consumedBy": ["slop_suggest_with_memory MCP tool", "future agent-fast-path tools"]
    },
    "health": {
      "$id": "https://usebrick.dev/schemas/health.schema.json",
      "file": "health.schema.json",
      "description": "Repository health snapshot from a single scan (Slop Index + per-category scores + issue counts).",
      "producedBy": ["slopbrick scan"],
      "consumedBy": ["website dashboards", "CI integrations", "future /projects pages"]
    }
  }
}
