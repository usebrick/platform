{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-bounded-shard-receipt.schema.json",
  "title": "AdmissionBoundedShardReceiptV1",
  "description": "Hash and ordered-range receipt for one generation-local overlap shard.",
  "type": "object",
  "additionalProperties": false,
  "required": ["shardId", "pathBase", "relativePath", "firstKey", "lastKey", "rowCount", "bytes", "sha256"],
  "properties": {
    "shardId": { "$ref": "#/$defs/id" },
    "pathBase": { "const": "generation_local" },
    "relativePath": { "$ref": "#/$defs/relativePath" },
    "firstKey": { "$ref": "#/$defs/key" },
    "lastKey": { "$ref": "#/$defs/key" },
    "rowCount": { "$ref": "#/$defs/nonNegativeInteger" },
    "bytes": { "type": "integer", "minimum": 1, "maximum": 67108864 },
    "sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nonNegativeInteger": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "key": { "type": "string", "pattern": "^(?=[ -~]+$).{1,512}$" },
    "relativePath": { "type": "string", "pattern": "^(?=[ -~]+$)(?!/)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*\\/$).+$" }
  }
}
