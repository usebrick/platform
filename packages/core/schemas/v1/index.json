{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repository Structure \u2014 Schema Index",
  "description": "Pointer to the four canonical schemas that define the usebrick.dev Repository Structure Platform. Every tool in the platform \u2014 slopbrick, stackpick, gir, the MCP server, future CI integrations \u2014 reads and writes data matching these schemas.",
  "schemas": {
    "inventory": {
      "$id": "https://usebrick.dev/schemas/v1/inventory.schema.json",
      "file": "inventory.schema.json",
      "description": "Detected pattern inventory + component fingerprints.",
      "producedBy": [
        "slopbrick scan"
      ],
      "consumedBy": [
        "slopbrick",
        "stackpick",
        "gir",
        "mcp"
      ]
    },
    "constitution": {
      "$id": "https://usebrick.dev/schemas/v1/constitution.schema.json",
      "file": "constitution.schema.json",
      "description": "Declared project constitution (allow-list + deny-list).",
      "producedBy": [
        "slopbrick scan (auto-detect from slopbrick.config.mjs)"
      ],
      "consumedBy": [
        "slopbrick drift",
        "stackpick",
        "gir",
        "mcp"
      ]
    },
    "health": {
      "$id": "https://usebrick.dev/schemas/v1/health.schema.json",
      "file": "health.schema.json",
      "description": "Repository health snapshot from a completed or partial scan. v5 (v0.21.0): four orthogonal scores \u2014 aiSlopScore (now RAW amount: 0=clean, 100=saturated, higher=worse; flipped from v0.20.1 inversion), engineeringHygiene, security, repositoryHealth (each 0-100, higher is better, with composite inverting aiSlopScore at the call site) \u2014 plus issue counts. Legacy slopIndex/categoryScores kept optional for backward compat with v0.14\u20130.20.1 readers. The v0.20.1 aiQuality alias is REMOVED in v5 (semantics now differ: old aiQuality: 70 = 70 cleaner, new aiSlopScore: 70 = 70% slop). Empty or not-applicable scans use the score-free scan-report envelope and do not produce this health artifact.",
      "producedBy": [
        "slopbrick scan"
      ],
      "consumedBy": [
        "website dashboards",
        "CI integrations",
        "future /projects pages"
      ]
    },
    "structure": {
      "$id": "https://usebrick.dev/schemas/v1/structure.schema.json",
      "file": "structure.schema.json",
      "description": "Structured JSON projection of inventory + constitution; structure.md is a derived Markdown rendering.",
      "producedBy": [
        "slopbrick scan (auto-renders to .slopbrick/structure.md)"
      ],
      "consumedBy": [
        "slop_suggest_with_structure MCP tool",
        "future agent-fast-path tools"
      ]
    },
    "calibration-corpus-manifest": {
      "$id": "https://usebrick.dev/schemas/v1/calibration-corpus-manifest.schema.json",
      "file": "calibration-corpus-manifest.schema.json",
      "description": "Immutable repository/file provenance manifest for the SlopBrick v10.3 calibration protocol. Consumers must validate this schema and run the versioned semantic verifier before selection or calibration. It is corpus metadata, not a release verdict.",
      "producedBy": [
        "reviewed corpus-manifest preparation"
      ],
      "consumedBy": [
        "slopbrick calibration selection",
        "slopbrick calibration verifier"
      ]
    },
    "calibration-run-manifest": {
      "$id": "https://usebrick.dev/schemas/v1/calibration-run-manifest.schema.json",
      "file": "calibration-run-manifest.schema.json",
      "description": "Portable, hash-pinned SlopBrick v10.3 calibration run record. It forbids checkout paths; those remain in the separate local checkout map.",
      "producedBy": ["slopbrick calibration control plane"],
      "consumedBy": ["slopbrick calibration verifier"]
    },
    "calibration-checkout-map": {
      "$id": "https://usebrick.dev/schemas/v1/calibration-checkout-map.schema.json",
      "file": "calibration-checkout-map.schema.json",
      "description": "Local-only mapping from pinned repository revisions to checkout paths. Its hash, not its paths, is recorded in canonical run artifacts.",
      "producedBy": ["local calibration environment"],
      "consumedBy": ["slopbrick calibration control plane"]
    },
    "calibration-observation": { "$id": "https://usebrick.dev/schemas/v1/calibration-observation.schema.json", "file": "calibration-observation.schema.json", "description": "One terminal v10.3 calibration observation per selected file.", "producedBy": ["slopbrick calibration scanner"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-failure": { "$id": "https://usebrick.dev/schemas/v1/calibration-failure.schema.json", "file": "calibration-failure.schema.json", "description": "Derived v10.3 terminal failure record.", "producedBy": ["slopbrick calibration scanner"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-coverage": { "$id": "https://usebrick.dev/schemas/v1/calibration-coverage.schema.json", "file": "calibration-coverage.schema.json", "description": "v10.3 overall and language/polarity coverage accounting.", "producedBy": ["slopbrick calibration verifier"], "consumedBy": ["slopbrick calibration reporting"] },
    "calibration-admission-policy": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-policy.schema.json", "file": "calibration-admission-policy.schema.json", "description": "Durable v10.3 admission policy and fixed smoke/canary gate limits.", "producedBy": ["slopbrick calibration admission control plane"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-admission-witness-policy": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-witness-policy.schema.json", "file": "calibration-admission-witness-policy.schema.json", "description": "Lossless deterministic search constraints derived from the admission policy.", "producedBy": ["slopbrick calibration admission control plane"], "consumedBy": ["slopbrick calibration witness search"] },
    "calibration-admission-tool-profile": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-tool-profile.schema.json", "file": "calibration-admission-tool-profile.schema.json", "description": "Frozen task-scoped executable, action, network, and resource authority profile.", "producedBy": ["reviewed admission authority bootstrap"], "consumedBy": ["slopbrick calibration admission control plane"] },
    "calibration-admission-invocation-intent": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-invocation-intent.schema.json", "file": "calibration-admission-invocation-intent.schema.json", "description": "Immutable pre-execution invocation authority intent.", "producedBy": ["slopbrick calibration admission control plane"], "consumedBy": ["slopbrick calibration tool receipt verifier"] },
    "calibration-admission-tool-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-tool-receipt.schema.json", "file": "calibration-admission-tool-receipt.schema.json", "description": "Immutable post-execution receipt bound to an invocation intent and primary output projection.", "producedBy": ["slopbrick calibration admission control plane"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-admission-tool-authority-index": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-tool-authority-index.schema.json", "file": "calibration-admission-tool-authority-index.schema.json", "description": "Hash-linked immutable generations indexing frozen profiles, invocation intents, and tool receipts.", "producedBy": ["slopbrick calibration tool-authority publisher"], "consumedBy": ["slopbrick calibration admission control plane"] },
    "calibration-admission-tool-authority-snapshot": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-tool-authority-snapshot.schema.json", "file": "calibration-admission-tool-authority-snapshot.schema.json", "description": "Content-addressed projection of a tool-authority index generation.", "producedBy": ["slopbrick calibration tool-authority publisher"], "consumedBy": ["slopbrick calibration admission verifier"] },
    "calibration-tool-authority-publication-lock": { "$id": "https://usebrick.dev/schemas/v1/calibration-tool-authority-publication-lock.schema.json", "file": "calibration-tool-authority-publication-lock.schema.json", "description": "Fixed-path lock and intended transaction binding for tool-authority publication.", "producedBy": ["slopbrick calibration tool-authority publisher"], "consumedBy": ["slopbrick calibration tool-authority recovery"] },
    "calibration-tool-authority-publication-transaction": { "$id": "https://usebrick.dev/schemas/v1/calibration-tool-authority-publication-transaction.schema.json", "file": "calibration-tool-authority-publication-transaction.schema.json", "description": "Recoverable tool-authority publication state machine and immutable output paths.", "producedBy": ["slopbrick calibration tool-authority publisher"], "consumedBy": ["slopbrick calibration tool-authority recovery"] },
    "calibration-nested-publication-handoff": { "$id": "https://usebrick.dev/schemas/v1/calibration-nested-publication-handoff.schema.json", "file": "calibration-nested-publication-handoff.schema.json", "description": "Transient parent-to-child publication handoff, including intent-authority companion publication.", "producedBy": ["slopbrick calibration publication engines"], "consumedBy": ["slopbrick calibration publication recovery"] },
    "calibration-admission-evidence-index": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-evidence-index.schema.json", "file": "calibration-admission-evidence-index.schema.json", "description": "Evidence claims and immutable/offline locators.", "producedBy": ["slopbrick calibration admission control plane"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-admission-evidence-payload": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-evidence-payload.schema.json", "file": "calibration-admission-evidence-payload.schema.json", "description": "One evidence payload descriptor and storage binding.", "producedBy": ["slopbrick calibration admission control plane"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-admission-evidence-payload-set": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-evidence-payload-set.schema.json", "file": "calibration-admission-evidence-payload-set.schema.json", "description": "Hash-bound set of offline evidence payload descriptors.", "producedBy": ["slopbrick calibration admission control plane"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-admission-evidence-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-evidence-receipt.schema.json", "file": "calibration-admission-evidence-receipt.schema.json", "description": "Offline evidence byte verification receipt.", "producedBy": ["slopbrick calibration admission control plane"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-admission-evidence-bundle": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-evidence-bundle.schema.json", "file": "calibration-admission-evidence-bundle.schema.json", "description": "Fixed-path admission evidence verification input bundle.", "producedBy": ["slopbrick calibration admission control plane"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-approved-evidence-acquisition": { "$id": "https://usebrick.dev/schemas/v1/calibration-approved-evidence-acquisition.schema.json", "file": "calibration-approved-evidence-acquisition.schema.json", "description": "Reviewed immutable HTTPS evidence acquisition authorization.", "producedBy": ["slopbrick calibration admission reviewers"], "consumedBy": ["slopbrick evidence acquisition"] },
    "calibration-evidence-acquisition-reservation": { "$id": "https://usebrick.dev/schemas/v1/calibration-evidence-acquisition-reservation.schema.json", "file": "calibration-evidence-acquisition-reservation.schema.json", "description": "One-use evidence acquisition reservation.", "producedBy": ["slopbrick evidence acquisition"], "consumedBy": ["slopbrick evidence acquisition recovery"] },
    "calibration-evidence-acquisition-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-evidence-acquisition-receipt.schema.json", "file": "calibration-evidence-acquisition-receipt.schema.json", "description": "Observed evidence acquisition receipt bound to CAS completion and tool authority.", "producedBy": ["slopbrick evidence acquisition"], "consumedBy": ["slopbrick admission verifier"] },
    "calibration-evidence-acquisition-envelope": { "$id": "https://usebrick.dev/schemas/v1/calibration-evidence-acquisition-envelope.schema.json", "file": "calibration-evidence-acquisition-envelope.schema.json", "description": "Cross-ledger evidence acquisition completion envelope.", "producedBy": ["slopbrick evidence acquisition publication"], "consumedBy": ["slopbrick admission verifier"] },
    "calibration-evidence-cas-primary-completion": { "$id": "https://usebrick.dev/schemas/v1/calibration-evidence-cas-primary-completion.schema.json", "file": "calibration-evidence-cas-primary-completion.schema.json", "description": "Immutable primary completion marker for an evidence CAS transaction.", "producedBy": ["slopbrick evidence CAS"], "consumedBy": ["slopbrick evidence acquisition publication"] },
    "calibration-admission-evidence-cas-transaction": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-evidence-cas-transaction.schema.json", "file": "calibration-admission-evidence-cas-transaction.schema.json", "description": "Recoverable evidence CAS transaction state.", "producedBy": ["slopbrick evidence CAS"], "consumedBy": ["slopbrick evidence CAS recovery"] },
    "calibration-admission-materialization-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-materialization-receipt.schema.json", "file": "calibration-admission-materialization-receipt.schema.json", "description": "Admission-owned materialization receipt binding source output and verified units.", "producedBy": ["slopbrick calibration materializer"], "consumedBy": ["slopbrick admission verifier"] },
    "calibration-admission-acquisition-index": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-acquisition-index.schema.json", "file": "calibration-admission-acquisition-index.schema.json", "description": "Hash-linked acquisition artifact index generation.", "producedBy": ["slopbrick acquisition publication"], "consumedBy": ["slopbrick admission verifier"] },
    "calibration-admission-acquisition-snapshot": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-acquisition-snapshot.schema.json", "file": "calibration-admission-acquisition-snapshot.schema.json", "description": "Content-addressed acquisition authority projection.", "producedBy": ["slopbrick acquisition publication"], "consumedBy": ["slopbrick admission verifier"] },
    "calibration-acquisition-publication-proposal": { "$id": "https://usebrick.dev/schemas/v1/calibration-acquisition-publication-proposal.schema.json", "file": "calibration-acquisition-publication-proposal.schema.json", "description": "Reviewed no-clobber acquisition artifact publication proposal.", "producedBy": ["slopbrick admission control plane"], "consumedBy": ["slopbrick acquisition publication"] },
    "calibration-acquisition-publication-lock": { "$id": "https://usebrick.dev/schemas/v1/calibration-acquisition-publication-lock.schema.json", "file": "calibration-acquisition-publication-lock.schema.json", "description": "Acquisition publication lock and intended transaction binding.", "producedBy": ["slopbrick acquisition publication"], "consumedBy": ["slopbrick acquisition recovery"] },
    "calibration-acquisition-publication-transaction": { "$id": "https://usebrick.dev/schemas/v1/calibration-acquisition-publication-transaction.schema.json", "file": "calibration-acquisition-publication-transaction.schema.json", "description": "Recoverable acquisition publication state machine.", "producedBy": ["slopbrick acquisition publication"], "consumedBy": ["slopbrick acquisition recovery"] },
    "calibration-acquisition-round-authorization": { "$id": "https://usebrick.dev/schemas/v1/calibration-acquisition-round-authorization.schema.json", "file": "calibration-acquisition-round-authorization.schema.json", "description": "Owner-approved one- or two-source acquisition-round authorization bound to a reviewed census deficit.", "producedBy": ["slopbrick admission reviewers"], "consumedBy": ["slopbrick acquisition round orchestrator"] },
    "calibration-approved-acquisition": { "$id": "https://usebrick.dev/schemas/v1/calibration-approved-acquisition.schema.json", "file": "calibration-approved-acquisition.schema.json", "description": "One owner-approved immutable Git or release-asset source acquisition authorization.", "producedBy": ["slopbrick admission reviewers"], "consumedBy": ["slopbrick acquisition round orchestrator"] },
    "calibration-acquisition-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-acquisition-receipt.schema.json", "file": "calibration-acquisition-receipt.schema.json", "description": "Observed source acquisition receipt bound to an approved acquisition and round transaction.", "producedBy": ["slopbrick acquisition child"], "consumedBy": ["slopbrick acquisition round orchestrator", "slopbrick admission verifier"] },
    "calibration-acquisition-round-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-acquisition-round-receipt.schema.json", "file": "calibration-acquisition-round-receipt.schema.json", "description": "Post-round receipt proving source count, byte cap, and child/orchestrator authority joins.", "producedBy": ["slopbrick acquisition round orchestrator"], "consumedBy": ["slopbrick acquisition publication", "slopbrick admission verifier"] },
    "calibration-acquisition-round-lock": { "$id": "https://usebrick.dev/schemas/v1/calibration-acquisition-round-lock.schema.json", "file": "calibration-acquisition-round-lock.schema.json", "description": "Fixed-path lock for a bounded acquisition-round transaction.", "producedBy": ["slopbrick acquisition round orchestrator"], "consumedBy": ["slopbrick acquisition recovery"] },
    "calibration-acquisition-round-transaction": { "$id": "https://usebrick.dev/schemas/v1/calibration-acquisition-round-transaction.schema.json", "file": "calibration-acquisition-round-transaction.schema.json", "description": "Recoverable acquisition-round state machine with explicit child paths and receipt phases.", "producedBy": ["slopbrick acquisition round orchestrator"], "consumedBy": ["slopbrick acquisition recovery"] },
    "calibration-admission-source-register": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-source-register.schema.json", "file": "calibration-admission-source-register.schema.json", "description": "Hash-bound v10.3 aggregate/material source register.", "producedBy": ["slopbrick calibration admission control plane"], "consumedBy": ["slopbrick calibration verifier", "slopbrick source:census"] },
    "calibration-source-review": { "$id": "https://usebrick.dev/schemas/v1/calibration-source-review.schema.json", "file": "calibration-source-review.schema.json", "description": "One v10.3 source review bound to one source-register entry.", "producedBy": ["slopbrick calibration admission reviewers"], "consumedBy": ["slopbrick calibration verifier", "slopbrick source:census"] },
    "calibration-admission-register-delta": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-register-delta.schema.json", "file": "calibration-admission-register-delta.schema.json", "description": "One-way v10.3 source-register growth delta bound to one or two reviewed source evidence sets.", "producedBy": ["slopbrick register-generation publisher"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-register-generation-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-register-generation-receipt.schema.json", "file": "calibration-register-generation-receipt.schema.json", "description": "Completed v10.3 register-generation receipt binding the delta, source generations, parent/next registers, lock, transaction, and tool receipt.", "producedBy": ["slopbrick register-generation publisher"], "consumedBy": ["slopbrick calibration verifier"] },
    "calibration-release-prerequisite-approval": { "$id": "https://usebrick.dev/schemas/v1/calibration-release-prerequisite-approval.schema.json", "file": "calibration-release-prerequisite-approval.schema.json", "description": "Independently reviewed approval of the release-plan prerequisite commit and evidence summary.", "producedBy": ["release asset plan reviewers"], "consumedBy": ["slopbrick calibration manifest builder"] },
    "calibration-score-wire-closure-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-score-wire-closure-receipt.schema.json", "file": "calibration-score-wire-closure-receipt.schema.json", "description": "Independently reviewed receipt closing the v10.3 score/wire contract at one implementation commit.", "producedBy": ["score/wire gate reviewers"], "consumedBy": ["slopbrick calibration manifest builder"] },
    "calibration-run-lifecycle-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-run-lifecycle-receipt.schema.json", "file": "calibration-run-lifecycle-receipt.schema.json", "description": "Independently reviewed terminal receipt for v10.3 run initialization or post-scan lifecycle verification.", "producedBy": ["run lifecycle gate reviewers"], "consumedBy": ["slopbrick calibration manifest builder"] },
    "calibration-packed-runtime-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-packed-runtime-receipt.schema.json", "file": "calibration-packed-runtime-receipt.schema.json", "description": "Independently reviewed Node 22 or Node 24 packed-runtime verification receipt for the v0.45.0 package.", "producedBy": ["packed runtime matrix reviewers"], "consumedBy": ["slopbrick calibration manifest builder"] },
    "calibration-register-generation-lock": { "$id": "https://usebrick.dev/schemas/v1/calibration-register-generation-lock.schema.json", "file": "calibration-register-generation-lock.schema.json", "description": "Fixed-path register-generation lock with intended transaction and recovery nonce.", "producedBy": ["slopbrick register-generation publisher"], "consumedBy": ["slopbrick register-generation recovery"] },
    "calibration-register-generation-transaction": { "$id": "https://usebrick.dev/schemas/v1/calibration-register-generation-transaction.schema.json", "file": "calibration-register-generation-transaction.schema.json", "description": "Recoverable v10.3 register-generation publication transaction and phase metadata.", "producedBy": ["slopbrick register-generation publisher"], "consumedBy": ["slopbrick register-generation recovery"] },
    "calibration-admission-artifact-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-artifact-receipt.schema.json", "file": "calibration-admission-artifact-receipt.schema.json", "description": "Hash and path receipt for one immutable admission-generation artifact.", "producedBy": ["slopbrick admission publisher"], "consumedBy": ["slopbrick admission verifier"] },
    "calibration-admission-source-generation-proposal": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-source-generation-proposal.schema.json", "file": "calibration-admission-source-generation-proposal.schema.json", "description": "Frozen source-generation proposal before independent approval.", "producedBy": ["slopbrick admission control plane"], "consumedBy": ["slopbrick source-generation publisher"] },
    "calibration-admission-source-generation-approval": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-source-generation-approval.schema.json", "file": "calibration-admission-source-generation-approval.schema.json", "description": "Independent blind-review approval for a source-generation proposal.", "producedBy": ["slopbrick admission reviewers"], "consumedBy": ["slopbrick source-generation publisher"] },
    "calibration-admission-source-generation": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-source-generation.schema.json", "file": "calibration-admission-source-generation.schema.json", "description": "Immutable source-generation artifact set and approval branch.", "producedBy": ["slopbrick source-generation publisher"], "consumedBy": ["slopbrick register-generation publisher", "slopbrick admission verifier"] },
    "calibration-admission-source-current": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-source-current.schema.json", "file": "calibration-admission-source-current.schema.json", "description": "Hash-bound current pointer for one source generation.", "producedBy": ["slopbrick source-generation publisher"], "consumedBy": ["slopbrick admission verifier", "slopbrick source-generation recovery"] },
    "calibration-admission-record": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-record.schema.json", "file": "calibration-admission-record.schema.json", "description": "One immutable v10.3 admission code-unit record.", "producedBy": ["slopbrick admission materializer"], "consumedBy": ["slopbrick admission verifier", "slopbrick source:census"] },
    "calibration-admission-record-stream": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-record-stream.schema.json", "file": "calibration-admission-record-stream.schema.json", "description": "Hash receipt for the canonical admission-record JSONL stream.", "producedBy": ["slopbrick admission materializer"], "consumedBy": ["slopbrick admission verifier", "slopbrick source:census"] },
    "calibration-admission-decision": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-decision.schema.json", "file": "calibration-admission-decision.schema.json", "description": "One blind-assignment-bound independent admission decision.", "producedBy": ["slopbrick admission reviewers"], "consumedBy": ["slopbrick admission verifier"] },
    "calibration-admission-review-sample": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-review-sample.schema.json", "file": "calibration-admission-review-sample.schema.json", "description": "Deterministic hash-bound blind-review sample selection.", "producedBy": ["slopbrick admission review sampler"], "consumedBy": ["slopbrick admission reviewers", "slopbrick admission verifier"] },
    "calibration-admission-decision-ledger": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-decision-ledger.schema.json", "file": "calibration-admission-decision-ledger.schema.json", "description": "Hash receipt joining records, decisions, assignments, and blind receipts.", "producedBy": ["slopbrick admission reviewers"], "consumedBy": ["slopbrick admission verifier", "slopbrick source:census"] },
    "calibration-admission-blind-assignment": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-blind-assignment.schema.json", "file": "calibration-admission-blind-assignment.schema.json", "description": "Pre-decision two-reviewer blind assignment.", "producedBy": ["slopbrick admission reviewers"], "consumedBy": ["slopbrick admission verifier"] },
    "calibration-admission-blind-review-receipt": { "$id": "https://usebrick.dev/schemas/v1/calibration-admission-blind-review-receipt.schema.json", "file": "calibration-admission-blind-review-receipt.schema.json", "description": "Post-decision receipt proving peer material stayed hidden.", "producedBy": ["slopbrick admission protocol auditor"], "consumedBy": ["slopbrick admission verifier"] },
