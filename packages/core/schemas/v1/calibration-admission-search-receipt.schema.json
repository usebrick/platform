{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-search-receipt.schema.json",
  "title": "AdmissionSearchReceiptV1",
  "description": "Post-execution deterministic witness-search receipt. The witness or certificate is created before this receipt.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "receiptId", "gate", "witnessPolicySha256", "eligibilitySnapshotSha256", "candidateOrderSha256", "visitedNodes", "prunedNodes", "terminal", "terminalArtifactSha256", "toolReceiptSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-search-receipt-v1" },
    "receiptId": { "$ref": "#/$defs/sha256" },
    "gate": { "enum": ["smoke", "canary"] },
    "witnessPolicySha256": { "$ref": "#/$defs/sha256" },
    "eligibilitySnapshotSha256": { "$ref": "#/$defs/sha256" },
    "candidateOrderSha256": { "$ref": "#/$defs/sha256" },
    "visitedNodes": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "prunedNodes": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "terminal": { "enum": ["witness", "proven_capacity_cut", "proven_exhaustive", "indeterminate_limit"] },
    "terminalArtifactSha256": { "$ref": "#/$defs/sha256" },
    "toolReceiptSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": { "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } }
}
