{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-acquisition-receipt.schema.json",
  "title": "CalibrationAcquisitionReceiptV1",
  "description": "Observed immutable source-acquisition receipt bound to one approved source authorization and one round transaction.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "receiptId", "authorizationId", "roundId", "authorizationSha256", "sourceId", "repositoryId", "materializationId", "originUrl", "transport", "materializedBytes", "inventorySha256", "licenseSha256", "materializationReceiptId", "materializationReceiptSha256", "networkObservation", "resolvedPublicAddressesSha256", "connectedPeerEvidenceSha256", "transactionId", "toolReceiptId", "toolReceiptSha256", "receiptSha256"],
  "properties": {
    "version": { "const": "v10.3-acquisition-receipt-v1" },
    "receiptId": { "$ref": "#/$defs/sha256" },
    "authorizationId": { "$ref": "#/$defs/sha256" },
    "roundId": { "$ref": "#/$defs/sha256" },
    "authorizationSha256": { "$ref": "#/$defs/sha256" },
    "sourceId": { "$ref": "#/$defs/slug" },
    "repositoryId": { "$ref": "#/$defs/slug" },
    "materializationId": { "$ref": "#/$defs/materializationId" },
    "originUrl": { "$ref": "#/$defs/httpsUrl" },
    "transport": { "$ref": "#/$defs/transport" },
    "materializedBytes": { "type": "integer", "minimum": 0, "maximum": 5368709120 },
    "inventorySha256": { "$ref": "#/$defs/sha256" },
    "licenseSha256": { "$ref": "#/$defs/sha256" },
    "materializationReceiptId": { "$ref": "#/$defs/id" },
    "materializationReceiptSha256": { "$ref": "#/$defs/sha256" },
    "networkObservation": { "$ref": "#/$defs/networkObservation" },
    "resolvedPublicAddressesSha256": { "$ref": "#/$defs/sha256" },
    "connectedPeerEvidenceSha256": { "$ref": "#/$defs/sha256" },
    "transactionId": { "$ref": "#/$defs/sha256" },
    "toolReceiptId": { "$ref": "#/$defs/sha256" },
    "toolReceiptSha256": { "$ref": "#/$defs/sha256" },
    "receiptSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "materializationId": { "type": "string", "pattern": "^sbm_[a-f0-9]{64}$" },
    "httpsUrl": { "type": "string", "format": "uri", "pattern": "^https://", "maxLength": 4096 },
    "relativePath": { "type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*//)[A-Za-z0-9._@+%=-]+(?:/[A-Za-z0-9._@+%=-]+)*$" },
    "releaseMaterialization": { "$ref": "https://usebrick.dev/schemas/v1/calibration-corpus-manifest.schema.json#/$defs/releaseArchiveMaterialization" },
    "transport": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "commitSha", "treeSha", "observedPackBytes", "observedNetworkBytes"],
          "properties": {
            "kind": { "const": "git_https" },
            "commitSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            "treeSha": { "$ref": "#/$defs/sha256" },
            "observedPackBytes": { "type": "integer", "minimum": 0, "maximum": 5368709120 },
            "observedNetworkBytes": { "const": "not_observable_exactly" }
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["kind", "materialization", "extractionReceipt", "observedTransferBytes", "redirectChain"],
          "properties": {
            "kind": { "const": "release_https" },
            "materialization": { "$ref": "#/$defs/releaseMaterialization" },
            "extractionReceipt": { "$ref": "#/$defs/extractionReceipt" },
            "observedTransferBytes": { "type": "integer", "minimum": 0, "maximum": 5368709120 },
            "redirectChain": { "type": "array", "items": { "$ref": "#/$defs/httpsUrl" } }
          }
        }
      ]
    },
    "networkObservation": {
      "type": "object", "additionalProperties": false,
      "required": ["requestUrl", "redirectChain", "resolvedPublicAddresses", "connectedPeerAddress"],
      "properties": {
        "requestUrl": { "$ref": "#/$defs/httpsUrl" },
        "redirectChain": { "type": "array", "items": { "$ref": "#/$defs/httpsUrl" } },
        "resolvedPublicAddresses": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
        "connectedPeerAddress": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "extractionReceipt": {
      "type": "object", "additionalProperties": false,
      "required": ["receiptVersion", "extractionPolicy", "assetSha256", "assetBytes", "inventorySha256", "entries"],
      "properties": {
        "receiptVersion": { "const": "v1" }, "extractionPolicy": { "const": "safe-zip-v1" },
        "assetSha256": { "$ref": "#/$defs/sha256" }, "assetBytes": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "inventorySha256": { "$ref": "#/$defs/sha256" },
        "entries": { "type": "array", "items": { "oneOf": [
          { "type": "object", "additionalProperties": false, "required": ["path", "kind"], "properties": { "path": { "$ref": "#/$defs/relativePath" }, "kind": { "const": "directory" } } },
          { "type": "object", "additionalProperties": false, "required": ["path", "kind", "bytes", "sha256"], "properties": { "path": { "$ref": "#/$defs/relativePath" }, "kind": { "const": "file" }, "bytes": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }, "sha256": { "$ref": "#/$defs/sha256" } } }
        ] } }
      }
    }
  }
}
