{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-source-generation.schema.json",
  "title": "CalibrationAdmissionSourceGenerationV1",
  "description": "Immutable source review/artifact generation. The directory is content addressed by generationSha256.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sourceId", "generation", "proposalId", "proposalSha256", "approval", "sourceReviewSha256", "artifacts", "artifactSetSha256", "generationSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-source-generation-v1" },
    "sourceId": { "$ref": "#/$defs/id" },
    "generation": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "parentGenerationSha256": { "$ref": "#/$defs/sha256" },
    "proposalId": { "$ref": "#/$defs/id" },
    "proposalSha256": { "$ref": "#/$defs/sha256" },
    "approval": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["kind", "reason"], "properties": { "kind": { "const": "genesis_quarantine" }, "reason": { "const": "review_incomplete" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "approvalId", "approvalSha256"], "properties": { "kind": { "const": "independent_review" }, "approvalId": { "$ref": "#/$defs/id" }, "approvalSha256": { "$ref": "#/$defs/sha256" } } }
      ]
    },
    "sourceReviewSha256": { "$ref": "#/$defs/sha256" },
    "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-artifact-receipt.schema.json" } },
    "artifactSetSha256": { "$ref": "#/$defs/sha256" },
    "generationSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
