{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-artifact-receipt.schema.json",
  "title": "CalibrationAdmissionArtifactReceiptV1",
  "description": "Content-addressed receipt for one source-generation artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": ["pathBase", "relativePath", "kind", "bytes", "sha256"],
  "properties": {
    "pathBase": { "enum": ["generation_local", "admission_root_content_addressed"] },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*//)[^\\u0000-\\u001f]+$"
    },
    "kind": {
      "enum": [
        "source_review", "review_sample", "review_decisions", "admission_records",
        "record_stream", "overlap_universe", "overlap_universe_stream", "shard",
        "checkpoint", "index", "receipt", "ledger", "bundle", "current_pointer"
      ]
    },
    "bytes": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
