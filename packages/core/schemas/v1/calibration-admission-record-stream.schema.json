{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-record-stream.schema.json",
  "title": "CalibrationAdmissionRecordStreamV1",
  "description": "Hash receipt for the canonical admission-record JSONL stream.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "relativePath", "recordsJsonlSha256", "recordCount", "recordIdSetSha256", "canonicalRecordHashesSha256", "streamSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-record-stream-v1" },
    "relativePath": { "const": "review/admission/admission-records.jsonl" },
    "recordsJsonlSha256": { "$ref": "#/$defs/sha256" },
    "recordCount": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "recordIdSetSha256": { "$ref": "#/$defs/sha256" },
    "canonicalRecordHashesSha256": { "$ref": "#/$defs/sha256" },
    "streamSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
