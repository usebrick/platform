{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-run-lifecycle-receipt.schema.json",
  "title": "CalibrationRunLifecycleReceiptV1",
  "description": "Independently reviewed terminal receipt for v10.3 run initialization or post-scan lifecycle verification.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "receiptId", "kind", "approvedCommitSha", "behaviorSha256", "verificationEvidenceSha256", "reviewerIds", "decision", "receiptSha256"],
  "properties": {
    "version": { "const": "v10.3-run-lifecycle-receipt-v1" },
    "receiptId": { "$ref": "#/$defs/id" },
    "kind": { "enum": ["run_init", "post_scan"] },
    "approvedCommitSha": { "$ref": "#/$defs/commitSha" },
    "behaviorSha256": { "$ref": "#/$defs/sha256" },
    "verificationEvidenceSha256": { "$ref": "#/$defs/sha256" },
    "reviewerIds": { "$ref": "#/$defs/reviewerIds" },
    "decision": { "const": "approved" },
    "receiptSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "commitSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" },
    "reviewerIds": {
      "type": "array",
      "prefixItems": [{ "$ref": "#/$defs/id" }, { "$ref": "#/$defs/id" }],
      "items": false,
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true
    }
  }
}
