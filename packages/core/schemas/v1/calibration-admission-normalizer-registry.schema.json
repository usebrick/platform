{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-normalizer-registry.schema.json",
  "title": "AdmissionNormalizerRegistryV1",
  "description": "Versioned language normalizer and shingle implementation registry for the v10.3 overlap authority.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "entries", "registrySha256"],
  "properties": {
    "version": { "const": "v10.3-admission-normalizers-v1" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    },
    "registrySha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "normalizerId", "implementationSha256", "fixturesSha256", "utf8Policy", "shingleSize"],
      "properties": {
        "language": { "type": "string", "minLength": 1, "maxLength": 128 },
        "normalizerId": { "$ref": "#/$defs/id" },
        "implementationSha256": { "$ref": "#/$defs/sha256" },
        "fixturesSha256": { "$ref": "#/$defs/sha256" },
        "utf8Policy": { "const": "strict" },
        "shingleSize": { "const": 5 }
      }
    }
  }
}
