{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-register-generation-receipt.schema.json",
  "title": "CalibrationRegisterGenerationReceiptV1",
  "description": "Post-publication receipt binding a register generation to its delta, lock, transaction, and tool receipt.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "receiptId", "generation", "deltaId", "sourceGenerationSha256s", "parentRegisterSha256", "nextRegisterSha256", "lockSha256", "transactionId", "toolReceiptSha256", "receiptSha256"],
  "properties": {
    "version": { "const": "v10.3-register-generation-receipt-v1" },
    "receiptId": { "$ref": "#/$defs/id" },
    "generation": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "deltaId": { "$ref": "#/$defs/id" },
    "sourceGenerationSha256s": { "type": "array", "minItems": 1, "maxItems": 2, "items": { "$ref": "#/$defs/sha256" } },
    "parentRegisterSha256": { "$ref": "#/$defs/sha256" },
    "nextRegisterSha256": { "$ref": "#/$defs/sha256" },
    "lockSha256": { "$ref": "#/$defs/sha256" },
    "transactionId": { "$ref": "#/$defs/id" },
    "toolReceiptSha256": { "$ref": "#/$defs/sha256" },
    "receiptSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" }
  }
}
