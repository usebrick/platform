{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-approved-evidence-acquisition.schema.json",
  "title": "CalibrationApprovedEvidenceAcquisitionV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "authorizationId", "approvedBy", "approvedAt", "evidenceId", "url", "approvedRedirectUrls", "expectedBytes", "expectedSha256", "expectedMediaType", "maxTransferBytes", "authorizationSha256"],
  "properties": {
    "version": { "const": "v10.3-approved-evidence-acquisition-v1" },
    "authorizationId": { "$ref": "#/$defs/id" },
    "approvedBy": { "type": "string", "minLength": 1, "maxLength": 255 },
    "approvedAt": { "type": "string", "format": "date-time" },
    "evidenceId": { "$ref": "#/$defs/id" },
    "url": { "$ref": "#/$defs/https" },
    "approvedRedirectUrls": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/https" } },
    "expectedBytes": { "$ref": "#/$defs/nonNegativeInteger" },
    "expectedSha256": { "$ref": "#/$defs/sha256" },
    "expectedMediaType": { "type": "string", "minLength": 1, "maxLength": 255 },
    "maxTransferBytes": { "$ref": "#/$defs/positiveInteger" },
    "authorizationSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$" },
    "https": { "type": "string", "pattern": "^https://[^\\s]+$" },
    "nonNegativeInteger": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "positiveInteger": { "type": "integer", "minimum": 1, "maximum": 5368709120 }
  }
}
