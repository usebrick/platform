{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-overlap-index-receipt.schema.json",
  "title": "AdmissionOverlapIndexReceiptV1",
  "description": "Hash-bound postings and candidate-pair index receipt.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "universeSha256", "normalizerRegistrySha256", "overlapPolicySha256", "method", "postingShards", "candidatePairShards", "checkpoints", "coveredCandidateUnits", "complete", "toolReceiptSha256", "receiptSha256"],
  "properties": {
    "version": { "const": "v10.3-overlap-index-receipt-v1" },
    "universeSha256": { "$ref": "#/$defs/sha256" },
    "normalizerRegistrySha256": { "$ref": "#/$defs/sha256" },
    "overlapPolicySha256": { "$ref": "#/$defs/sha256" },
    "method": { "const": "prefix-filter-exact-jaccard-0.80-v1" },
    "postingShards": { "type": "array", "maxItems": 65536, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-bounded-shard-receipt.schema.json" } },
    "candidatePairShards": { "type": "array", "maxItems": 65536, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-bounded-shard-receipt.schema.json" } },
    "checkpoints": { "type": "array", "maxItems": 65536, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-overlap-checkpoint.schema.json" } },
    "coveredCandidateUnits": { "$ref": "#/$defs/nonNegativeInteger" },
    "complete": { "type": "boolean" },
    "toolReceiptSha256": { "$ref": "#/$defs/sha256" },
    "receiptSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nonNegativeInteger": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
  }
}
