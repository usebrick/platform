{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-overlap-universe.schema.json",
  "title": "AdmissionOverlapUniverseV1",
  "description": "Hash-bound summary for the canonical v10.3 global overlap universe stream.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "registerSha256", "recordsJsonlSha256", "selectedAggregateCoverage", "baselineMaterialUnits", "repositoryMaterialUnits", "newCandidateUnits", "covered", "unsupported", "unreadable", "unresolvedCandidateUnitIds", "normalizerRegistrySha256", "universeSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-overlap-universe-v1" },
    "registerSha256": { "$ref": "#/$defs/sha256" },
    "recordsJsonlSha256": { "$ref": "#/$defs/sha256" },
    "selectedAggregateCoverage": { "$ref": "#/$defs/nonNegativeInteger" },
    "baselineMaterialUnits": { "$ref": "#/$defs/nonNegativeInteger" },
    "repositoryMaterialUnits": { "$ref": "#/$defs/nonNegativeInteger" },
    "newCandidateUnits": { "$ref": "#/$defs/nonNegativeInteger" },
    "covered": { "$ref": "#/$defs/nonNegativeInteger" },
    "unsupported": { "$ref": "#/$defs/nonNegativeInteger" },
    "unreadable": { "$ref": "#/$defs/nonNegativeInteger" },
    "unresolvedCandidateUnitIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "normalizerRegistrySha256": { "$ref": "#/$defs/sha256" },
    "universeSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" },
    "nonNegativeInteger": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
  }
}
