{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-evidence-acquisition-envelope.schema.json",
  "title": "CalibrationEvidenceAcquisitionEnvelopeV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "envelopeId", "authorizationId", "reservation", "invocationIntentId", "casTransactionId", "primaryCompletionRelativePath", "primaryCompletionSha256", "acquisitionReceiptSha256", "payloadId", "toolReceiptSha256", "envelopeSha256"],
  "properties": {
    "version": { "const": "v10.3-evidence-acquisition-envelope-v1" },
    "envelopeId": { "$ref": "#/$defs/sha256" },
    "authorizationId": { "$ref": "#/$defs/id" },
    "reservation": { "$ref": "#/$defs/reservation" },
    "invocationIntentId": { "$ref": "#/$defs/sha256" },
    "casTransactionId": { "$ref": "#/$defs/id" },
    "primaryCompletionRelativePath": { "$ref": "#/$defs/relativePath" },
    "primaryCompletionSha256": { "$ref": "#/$defs/sha256" },
    "acquisitionReceiptSha256": { "$ref": "#/$defs/sha256" },
    "payloadId": { "$ref": "#/$defs/id" },
    "toolReceiptSha256": { "$ref": "#/$defs/sha256" },
    "envelopeSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$" },
    "relativePath": { "type": "string", "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))[^\\x00-\\x1f]+$" },
    "reservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "reservationId", "authorizationId", "invocationIntentId", "recoveryNonce", "reservationSha256"],
      "properties": {
        "version": { "const": "v10.3-evidence-acquisition-reservation-v1" },
        "reservationId": { "$ref": "#/$defs/sha256" },
        "authorizationId": { "$ref": "#/$defs/id" },
        "invocationIntentId": { "$ref": "#/$defs/sha256" },
        "recoveryNonce": { "$ref": "#/$defs/sha256" },
        "reservationSha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
