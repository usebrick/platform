{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-checkout-map.schema.json",
  "title": "SlopBrick v10.3 Calibration Checkout Map (local-only)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "runId", "entries"],
  "properties": {
    "version": { "const": "v10.3" },
    "runId": { "$ref": "#/$defs/identifier" },
    "entries": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/entry" } }
  },
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "sha": { "type": "string", "pattern": "^[a-f0-9]{40,64}$" },
    "entry": {
      "type": "object", "additionalProperties": false,
      "required": ["repositoryId", "commitSha", "checkoutPath"],
      "properties": {
        "repositoryId": { "$ref": "#/$defs/identifier" },
        "commitSha": { "$ref": "#/$defs/sha" },
        "checkoutPath": { "type": "string", "minLength": 2, "pattern": "^(?:/|[A-Za-z]:[\\\\/]).+" }
      }
    }
  }
}
