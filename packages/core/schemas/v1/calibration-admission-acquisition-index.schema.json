{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-acquisition-index.schema.json",
  "title": "CalibrationAdmissionAcquisitionIndexV1",
  "description": "Hash-linked immutable acquisition artifact index generation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generation", "artifacts", "indexSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-acquisition-index-v1" },
    "generation": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "parentIndexSha256": { "$ref": "#/$defs/sha256" },
    "artifacts": { "type": "array", "items": { "$ref": "#/$defs/artifact" } },
    "indexSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$" },
    "relativePath": { "type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*//)[^\\x00-\\x1f]+$" },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "objectId", "relativePath", "sha256"],
      "properties": {
        "kind": { "enum": ["evidence_authorization", "source_authorization", "round_authorization", "evidence_receipt", "evidence_cas_primary_completion", "source_receipt", "round_receipt", "materialization_receipt", "materialization_receipt_ledger", "evidence_envelope", "evidence_index", "evidence_payload_set", "evidence_verification_receipt_ledger", "evidence_bundle"] },
        "objectId": { "$ref": "#/$defs/id" },
        "relativePath": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
