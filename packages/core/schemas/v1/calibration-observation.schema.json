{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://usebrick.dev/schemas/v1/calibration-observation.schema.json",
  "type":"object", "additionalProperties":false,
  "required":["version","runId","fileId","repositoryId","familyId","language","polarity","status"],
  "properties":{"version":{"const":"v10.3"},"runId":{"type":"string","minLength":1},"fileId":{"type":"string","minLength":1},"repositoryId":{"type":"string","minLength":1},"familyId":{"type":"string","minLength":1},"language":{"type":"string","minLength":1},"polarity":{"enum":["verified_ai","verified_human"]},"status":{"enum":["success_findings","success_zero","excluded","parse_failure","timeout","scanner_failure"]},"findingsCount":{"type":"integer","minimum":0},"exclusionReason":{"type":"string","minLength":1},"failureCode":{"type":"string","minLength":1},"ruleEvidence":{"type":"array","uniqueItems":true,"items":{"type":"object","additionalProperties":false,"required":["ruleId","category","aiSpecific","severity","count"],"properties":{"ruleId":{"type":"string","pattern":"^[A-Za-z0-9][A-Za-z0-9._/-]*$"},"category":{"enum":["visual","typo","wcag","layout","component","logic","arch","perf","security","test","docs","db","ai","context","product","i18n"]},"aiSpecific":{"type":"boolean"},"severity":{"enum":["low","medium","high"]},"count":{"type":"integer","minimum":1}}}}},
  "oneOf":[
    {"properties":{"status":{"const":"success_findings"},"findingsCount":{"type":"integer","minimum":1},"exclusionReason":false,"failureCode":false},"required":["status","findingsCount"]},
    {"properties":{"status":{"const":"success_zero"},"findingsCount":{"type":"integer","const":0},"exclusionReason":false,"failureCode":false},"required":["status","findingsCount"]},
    {"properties":{"status":{"const":"excluded"},"findingsCount":false,"exclusionReason":{"type":"string","minLength":1},"failureCode":false,"ruleEvidence":false},"required":["status","exclusionReason"]},
    {"properties":{"status":{"enum":["parse_failure","timeout","scanner_failure"]},"findingsCount":false,"exclusionReason":false,"failureCode":{"type":"string","minLength":1},"ruleEvidence":false},"required":["status","failureCode"]}
  ]
}
