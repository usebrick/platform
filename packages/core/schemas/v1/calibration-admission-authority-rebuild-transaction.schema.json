{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-authority-rebuild-transaction.schema.json",
  "title": "CalibrationAdmissionAuthorityRebuildTransactionV1",
  "description": "Recoverable state machine for publishing one immutable static admission-authority generation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "transactionId", "lockSha256", "invocationIntentId", "inputGenerationProposalId", "inputGenerationProposalSha256", "operation", "expectedCurrentState", "recoveryNonce", "inputGenerationRelativePath", "staticGenerationStagingRelativePath", "authorityCurrentTemporaryRelativePath", "authorityCurrentFinalRelativePath", "sourceGenerationDirectories", "state", "transactionSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-authority-rebuild-transaction-v1" },
    "transactionId": { "$ref": "#/$defs/id" },
    "lockSha256": { "$ref": "#/$defs/sha256" },
    "invocationIntentId": { "$ref": "#/$defs/sha256" },
    "inputGenerationProposalId": { "$ref": "#/$defs/id" },
    "inputGenerationProposalSha256": { "$ref": "#/$defs/sha256" },
    "operation": { "enum": ["create", "replace"] },
    "expectedCurrentState": { "$ref": "#/$defs/expectedCurrentState" },
    "recoveryNonce": { "$ref": "#/$defs/sha256" },
    "inputGenerationRelativePath": { "$ref": "#/$defs/relativePath" },
    "staticGenerationStagingRelativePath": { "$ref": "#/$defs/relativePath" },
    "authorityCurrentTemporaryRelativePath": { "$ref": "#/$defs/relativePath" },
    "authorityCurrentFinalRelativePath": { "const": "review/admission/authority/current.json" },
    "sourceGenerationDirectories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 452382,
      "items": { "$ref": "#/$defs/sourceGenerationDirectory" }
    },
    "state": {
      "oneOf": [
        { "$ref": "#/$defs/intentState" },
        { "$ref": "#/$defs/inputState" },
        { "$ref": "#/$defs/primaryStaticOutputsState" },
        { "$ref": "#/$defs/toolReceiptState" },
        { "$ref": "#/$defs/publishedState" }
      ]
    },
    "transactionSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" },
    "relativePath": { "type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*[\\u0000-\\u001f])[^/]+(?:/[^/]+)*$" },
    "expectedCurrentState": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["kind"], "properties": { "kind": { "const": "absent" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "staticGenerationSha256"], "properties": { "kind": { "const": "existing" }, "staticGenerationSha256": { "$ref": "#/$defs/sha256" } } }
      ]
    },
    "sourceGenerationDirectory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "generationSha256", "artifactSetSha256", "generationStagingRelativePath", "generationFinalRelativePath", "generationsParentRelativePath", "currentPointerTemporaryRelativePath", "currentPointerFinalRelativePath"],
      "properties": {
        "sourceId": { "$ref": "#/$defs/id" },
        "generationSha256": { "$ref": "#/$defs/sha256" },
        "artifactSetSha256": { "$ref": "#/$defs/sha256" },
        "generationStagingRelativePath": { "$ref": "#/$defs/relativePath" },
        "generationFinalRelativePath": { "$ref": "#/$defs/relativePath" },
        "generationsParentRelativePath": { "$ref": "#/$defs/relativePath" },
        "priorGenerationRelativePath": { "$ref": "#/$defs/relativePath" },
        "currentPointerTemporaryRelativePath": { "$ref": "#/$defs/relativePath" },
        "currentPointerFinalRelativePath": { "$ref": "#/$defs/relativePath" }
      }
    },
    "intentState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase"],
      "properties": { "phase": { "const": "intent_fsynced" } }
    },
    "inputState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "inputGenerationSha256"],
      "properties": {
        "phase": { "enum": ["source_generation_directories_staged_fsynced", "source_generation_directories_promoted", "source_generation_parents_fsynced", "input_generation_fsynced", "overlap_generation_verified"] },
        "inputGenerationSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "primaryStaticOutputsState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "inputGenerationSha256", "overlapGenerationSha256", "primaryOutputSetSha256"],
      "properties": {
        "phase": { "const": "primary_static_outputs_fsynced" },
        "inputGenerationSha256": { "$ref": "#/$defs/sha256" },
        "overlapGenerationSha256": { "$ref": "#/$defs/sha256" },
        "primaryOutputSetSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "toolReceiptState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "inputGenerationSha256", "overlapGenerationSha256", "primaryOutputSetSha256", "toolReceiptId", "toolReceiptSha256", "toolAuthorityIndexSha256"],
      "properties": {
        "phase": { "const": "tool_receipt_indexed" },
        "inputGenerationSha256": { "$ref": "#/$defs/sha256" },
        "overlapGenerationSha256": { "$ref": "#/$defs/sha256" },
        "primaryOutputSetSha256": { "$ref": "#/$defs/sha256" },
        "toolReceiptId": { "$ref": "#/$defs/id" },
        "toolReceiptSha256": { "$ref": "#/$defs/sha256" },
        "toolAuthorityIndexSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "publishedState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "inputGenerationSha256", "overlapGenerationSha256", "primaryOutputSetSha256", "toolReceiptId", "toolReceiptSha256", "toolAuthorityIndexSha256", "staticGenerationSha256", "staticGenerationRelativePath"],
      "properties": {
        "phase": { "enum": ["static_generation_staged_fsynced", "static_generation_promoted", "static_generations_parent_fsynced", "source_current_pointers_promoted", "authority_current_promoted", "output_directories_fsynced", "complete"] },
        "inputGenerationSha256": { "$ref": "#/$defs/sha256" },
        "overlapGenerationSha256": { "$ref": "#/$defs/sha256" },
        "primaryOutputSetSha256": { "$ref": "#/$defs/sha256" },
        "toolReceiptId": { "$ref": "#/$defs/id" },
        "toolReceiptSha256": { "$ref": "#/$defs/sha256" },
        "toolAuthorityIndexSha256": { "$ref": "#/$defs/sha256" },
        "staticGenerationSha256": { "$ref": "#/$defs/sha256" },
        "staticGenerationRelativePath": { "$ref": "#/$defs/relativePath" }
      }
    }
  }
}
