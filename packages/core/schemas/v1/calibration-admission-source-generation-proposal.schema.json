{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-source-generation-proposal.schema.json",
  "title": "CalibrationAdmissionSourceGenerationProposalV1",
  "description": "Frozen source-generation input. Approval and future register hashes are intentionally absent.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "proposalId", "sourceId", "operation", "expectedCurrentState", "sourceReviewSha256", "materializationAuthority", "artifacts", "proposalSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-source-generation-proposal-v1" },
    "proposalId": { "$ref": "#/$defs/id" },
    "sourceId": { "$ref": "#/$defs/id" },
    "operation": { "enum": ["create", "replace"] },
    "expectedCurrentState": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["kind"], "properties": { "kind": { "const": "absent" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "generationSha256"], "properties": { "kind": { "const": "existing" }, "generationSha256": { "$ref": "#/$defs/sha256" } } }
      ]
    },
    "sourceReviewSha256": { "$ref": "#/$defs/sha256" },
    "materializationAuthority": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["kind", "evidenceBundleSha256"], "properties": { "kind": { "const": "genesis" }, "evidenceBundleSha256": { "$ref": "#/$defs/sha256" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "acquisitionIndexGenerationSha256", "materializationReceiptId", "materializationReceiptSha256"], "properties": { "kind": { "const": "acquired" }, "acquisitionIndexGenerationSha256": { "$ref": "#/$defs/sha256" }, "materializationReceiptId": { "$ref": "#/$defs/id" }, "materializationReceiptSha256": { "$ref": "#/$defs/sha256" } } }
      ]
    },
    "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-artifact-receipt.schema.json" } },
    "proposalSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
