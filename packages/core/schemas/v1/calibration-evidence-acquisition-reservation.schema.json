{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-evidence-acquisition-reservation.schema.json",
  "title": "CalibrationEvidenceAcquisitionReservationV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "reservationId", "authorizationId", "invocationIntentId", "recoveryNonce", "reservationSha256"],
  "properties": {
    "version": { "const": "v10.3-evidence-acquisition-reservation-v1" },
    "reservationId": { "$ref": "#/$defs/sha256" },
    "authorizationId": { "$ref": "#/$defs/id" },
    "invocationIntentId": { "$ref": "#/$defs/sha256" },
    "recoveryNonce": { "$ref": "#/$defs/sha256" },
    "reservationSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$" }
  }
}
