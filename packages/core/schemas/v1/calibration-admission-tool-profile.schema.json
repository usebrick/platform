{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-tool-profile.schema.json",
  "title": "CalibrationAdmissionToolProfileV1",
  "description": "Frozen task-scoped authority profile. Runtime validation owns the exact twelve IDs and action/network ownership table.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "profileId", "allowedExecutableIds", "allowedActions", "candidateByteAccess", "network", "resourceLimits", "profileSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-tool-profile-v1" },
    "profileId": { "enum": ["admission-core-contract-v1", "admission-context-v1", "admission-static-ledgers-v1", "admission-census-v1", "admission-manifest-v1", "admission-acquisition-publication-v1", "admission-source-node-v1", "admission-source-parquet-v1", "admission-acquisition-round-v1", "admission-git-acquire-v1", "admission-release-acquire-v1", "admission-evidence-acquire-v1"] },
    "allowedExecutableIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" } },
    "allowedActions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{0,127}$" } },
    "candidateByteAccess": { "enum": ["none", "read_only"] },
    "network": { "$ref": "#/$defs/network" },
    "resourceLimits": { "type": "object", "additionalProperties": { "oneOf": [{ "type": "number" }, { "type": "string" }] } },
    "profileSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "network": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["mode"], "properties": { "mode": { "const": "deny" } } },
        { "type": "object", "additionalProperties": false, "required": ["mode", "transport"], "properties": { "mode": { "const": "exact_authorized_https" }, "transport": { "enum": ["git", "release_asset", "evidence"] } } }
      ]
    }
  }
}
