{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-policy.schema.json",
  "title": "CalibrationAdmissionPolicyV1",
  "description": "Durable, immutable v10.3 admission policy. Runtime validation additionally binds the policy self-hash and the exact frozen tool-profile set.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "policyId", "initialRegisterEntryCount", "selectedCoverage", "baselineMaterialUnits", "repositoryMaterialUnits", "labels", "evidenceCasPolicy", "overlapPolicy", "reasonVocabularySha256", "toolProfileSha256s", "smoke", "canary", "policySha256"],
  "properties": {
    "version": { "const": "v10.3-admission-policy-v1" },
    "policyId": { "const": "v10.3-admission-v1" },
    "initialRegisterEntryCount": { "const": 329 },
    "selectedCoverage": { "const": 452382 },
    "baselineMaterialUnits": { "const": 58089 },
    "repositoryMaterialUnits": { "const": 394293 },
    "labels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["positive", "negative"],
      "properties": { "positive": { "const": "verified_ai" }, "negative": { "const": "verified_human" } }
    },
    "evidenceCasPolicy": { "const": "sha256-wx-fsync-v1" },
    "overlapPolicy": { "const": "prefix-filter-exact-jaccard-0.80-v1" },
    "reasonVocabularySha256": { "$ref": "#/$defs/sha256" },
    "toolProfileSha256s": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/sha256" } },
    "smoke": { "$ref": "#/$defs/smoke" },
    "canary": { "$ref": "#/$defs/canary" },
    "policySha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "positiveInteger": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "smoke": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unitsPerPolarity", "maxSourceOrFamilyUnitsPerPolarity", "minimumSourcesPerPolarity", "minimumFamiliesPerPolarity", "minimumLanguages", "minimumUnitsPerRepresentedLanguagePerPolarity"],
      "properties": {
        "unitsPerPolarity": { "const": 100 },
        "maxSourceOrFamilyUnitsPerPolarity": { "const": 50 },
        "minimumSourcesPerPolarity": { "const": 2 },
        "minimumFamiliesPerPolarity": { "const": 3 },
        "minimumLanguages": { "const": 2 },
        "minimumUnitsPerRepresentedLanguagePerPolarity": { "const": 20 }
      }
    },
    "canary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unitsPerPolarity", "maxSourceUnitsPerPolarity", "maxFamilyUnitsPerPolarity", "minimumSourcesPerPolarity", "minimumFamiliesPerPolarity", "minimumLanguages", "minimumUnitsPerLanguagePerPolarity", "minimumFamiliesPerLanguagePerPolarity", "minimumAiGeneratorFamilies"],
      "properties": {
        "unitsPerPolarity": { "const": 5000 },
        "maxSourceUnitsPerPolarity": { "const": 500 },
        "maxFamilyUnitsPerPolarity": { "const": 1000 },
        "minimumSourcesPerPolarity": { "const": 10 },
        "minimumFamiliesPerPolarity": { "const": 5 },
        "minimumLanguages": { "const": 3 },
        "minimumUnitsPerLanguagePerPolarity": { "const": 250 },
        "minimumFamiliesPerLanguagePerPolarity": { "const": 3 },
        "minimumAiGeneratorFamilies": { "const": 3 }
      }
    }
  }
}
