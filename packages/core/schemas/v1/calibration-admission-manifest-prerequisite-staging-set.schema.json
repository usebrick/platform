{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-manifest-prerequisite-staging-set.schema.json",
  "title": "CalibrationAdmissionManifestPrerequisiteStagingSetV1",
  "description": "Hash-bound staging projection for prerequisite artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "entries", "stagingSetSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-manifest-prerequisite-staging-set-v1" },
    "entries": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/entry" } },
    "stagingSetSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "path": { "type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)[^\\u0000-\\u001f]+$" },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactId", "kind", "mediaType", "normalizedRelativePath", "bytes", "sha256"],
      "properties": {
        "artifactId": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["release_plan", "release_plan_approval", "score_wire_closure_receipt", "run_init_receipt", "post_scan_receipt", "packed_runtime_receipt", "package_tarball", "manifest_builder"] },
        "mediaType": { "enum": ["text/markdown", "application/json", "application/gzip", "application/javascript"] },
        "normalizedRelativePath": { "$ref": "#/$defs/path" },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
