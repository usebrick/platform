{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-overlap-generation.schema.json",
  "title": "AdmissionOverlapGenerationV1",
  "description": "Immutable, content-addressed generation of the v10.3 global overlap authority.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generation", "inputGenerationSha256", "universeSha256", "overlapPolicySha256", "artifactSetSha256", "artifacts", "toolAuthoritySnapshot", "generationSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-overlap-generation-v1" },
    "generation": { "$ref": "#/$defs/nonNegativeInteger" },
    "parentGenerationSha256": { "$ref": "#/$defs/sha256" },
    "inputGenerationSha256": { "$ref": "#/$defs/sha256" },
    "universeSha256": { "$ref": "#/$defs/sha256" },
    "overlapPolicySha256": { "$ref": "#/$defs/sha256" },
    "artifactSetSha256": { "$ref": "#/$defs/sha256" },
    "artifacts": { "type": "array", "maxItems": 65536, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-artifact-receipt.schema.json" } },
    "toolAuthoritySnapshot": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-tool-authority-snapshot.schema.json" },
    "generationSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nonNegativeInteger": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
  }
}
