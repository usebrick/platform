{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-manifest-current.schema.json",
  "title": "CalibrationAdmissionManifestCurrentV1",
  "description": "Self-hashed current pointer for one admission manifest generation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "manifestId", "generation", "generationSha256", "generationRelativePath", "currentSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-manifest-current-v1" },
    "manifestId": { "$ref": "#/$defs/manifestId" },
    "generation": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "generationSha256": { "$ref": "#/$defs/sha256" },
    "generationRelativePath": { "$ref": "#/$defs/path" },
    "currentSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "manifestId": { "enum": ["v10.3-admission-smoke", "v10.3-admission-canary"] },
    "path": { "type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)[^\\u0000-\\u001f]+$" }
  }
}
