{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-witness-policy.schema.json",
  "title": "AdmissionWitnessPolicyV1",
  "description": "Durable search constraints derived losslessly from the v10.3 admission policy. Runtime validation recomputes the expansion and both self-hashes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "policyId", "gate", "algorithm", "seed", "maxSearchNodes", "constraints", "constraintsSha256", "witnessPolicySha256"],
  "properties": {
    "version": { "const": "v10.3-admission-witness-policy-v1" },
    "policyId": { "const": "v10.3-admission-v1" },
    "gate": { "enum": ["smoke", "canary"] },
    "algorithm": { "const": "lexicographic-bnb-feasibility-v1" },
    "seed": { "const": "slopbrick-v10.3-admission-review-v1" },
    "maxSearchNodes": { "enum": [10000000, 50000000] },
    "constraints": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/constraint" } },
    "constraintsSha256": { "$ref": "#/$defs/sha256" },
    "witnessPolicySha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["constraintId", "kind"],
      "properties": {
        "constraintId": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]{0,127}$" },
        "kind": { "enum": ["exact", "minimum", "maximum", "same_split"] },
        "integerValue": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
      }
    }
  }
}
