{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-tool-authority-snapshot.schema.json",
  "title": "CalibrationAdmissionToolAuthoritySnapshotV1",
  "description": "Content-addressed projection of one immutable tool-authority index generation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "indexGenerationSha256", "profileIds", "invocationIntentIds", "receiptIds", "snapshotSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-tool-authority-snapshot-v1" },
    "indexGenerationSha256": { "$ref": "#/$defs/sha256" },
    "profileIds": { "type": "array", "items": { "$ref": "#/$defs/profileId" } },
    "invocationIntentIds": { "type": "array", "items": { "$ref": "#/$defs/sha256" } },
    "receiptIds": { "type": "array", "items": { "$ref": "#/$defs/sha256" } },
    "snapshotSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "profileId": { "enum": ["admission-core-contract-v1", "admission-context-v1", "admission-static-ledgers-v1", "admission-census-v1", "admission-manifest-v1", "admission-acquisition-publication-v1", "admission-source-node-v1", "admission-source-parquet-v1", "admission-acquisition-round-v1", "admission-git-acquire-v1", "admission-release-acquire-v1", "admission-evidence-acquire-v1"] }
  }
}
