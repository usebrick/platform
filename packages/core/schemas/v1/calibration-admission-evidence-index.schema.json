{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-evidence-index.schema.json",
  "title": "CalibrationAdmissionEvidenceIndexV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "items", "indexSha256"],
  "properties": {
    "version": { "const": "v10.3-admission-evidence-index-v1" },
    "items": { "type": "array", "items": { "$ref": "#/$defs/item" } },
    "indexSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$" },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceId", "kind", "locator", "bytes", "mediaType", "sha256", "claimScopes"],
      "properties": {
        "evidenceId": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["source_origin", "license_terms", "rights_chain", "authorship_attestation", "generation_record", "provider_versioning_contract", "review_protocol"] },
        "locator": { "$ref": "#/$defs/locator" },
        "bytes": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "mediaType": { "type": "string", "minLength": 1, "maxLength": 255 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "claimScopes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 255 } }
      }
    },
    "locator": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["kind", "url", "immutability"], "properties": { "kind": { "const": "immutable_https" }, "url": { "type": "string", "pattern": "^https://[^\\s]+$" }, "immutability": { "enum": ["commit_pinned_git_blob", "content_addressed_release_asset"] } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "materializationId", "normalizedPath"], "properties": { "kind": { "const": "materialized_file" }, "materializationId": { "$ref": "#/$defs/id" }, "normalizedPath": { "$ref": "#/$defs/relativePath" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "localEvidenceId"], "properties": { "kind": { "const": "local_unpublished" }, "localEvidenceId": { "$ref": "#/$defs/id" } } }
      ]
    },
    "relativePath": { "type": "string", "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))[^\\x00-\\x1f]+$" }
  }
}
