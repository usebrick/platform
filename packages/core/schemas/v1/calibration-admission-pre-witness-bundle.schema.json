{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-pre-witness-bundle.schema.json",
  "title": "AdmissionPreWitnessBundleV1",
  "description": "Hash-bound static admission inputs. This boundary is intentionally witness-free: witness targets, decisions, and receipts are published only after this bundle is complete.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "admissionRecordSetSha256",
    "recordStreamSha256",
    "privacyLedgerSha256",
    "qualityLedgerSha256",
    "lineageLedgerSha256",
    "overlapGenerationSha256",
    "toolReceiptSha256",
    "artifacts",
    "preWitnessSha256"
  ],
  "properties": {
    "version": { "const": "v10.3-admission-pre-witness-bundle-v1" },
    "admissionRecordSetSha256": { "$ref": "#/$defs/sha256" },
    "recordStreamSha256": { "$ref": "#/$defs/sha256" },
    "privacyLedgerSha256": { "$ref": "#/$defs/sha256" },
    "qualityLedgerSha256": { "$ref": "#/$defs/sha256" },
    "lineageLedgerSha256": { "$ref": "#/$defs/sha256" },
    "overlapGenerationSha256": { "$ref": "#/$defs/sha256" },
    "toolReceiptSha256": { "$ref": "#/$defs/sha256" },
    "artifacts": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/artifact" }
    },
    "preWitnessSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "relativePath", "sha256"],
      "properties": {
        "kind": {
          "enum": ["lineage_ledger", "overlap_generation", "privacy_ledger", "quality_ledger", "record_stream"]
        },
        "relativePath": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{0,255}$"
        },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
