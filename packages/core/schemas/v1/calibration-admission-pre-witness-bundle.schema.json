{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://usebrick.dev/schemas/v1/calibration-admission-pre-witness-bundle.schema.json",
  "title": "CalibrationAdmissionPreWitnessBundleV1",
  "description": "Hash-bound rich pre-witness admission inputs. Witness search and review authority is persisted separately and never embedded here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "policy",
    "witnessPolicies",
    "toolProfiles",
    "invocationIntents",
    "toolReceipts",
    "toolAuthoritySnapshot",
    "sourceRegister",
    "registerDeltas",
    "registerGenerationReceipts",
    "sourceReviews",
    "reviewSamples",
    "decisionLedgers",
    "admissionRecordStream",
    "preWitnessDecisions",
    "preWitnessBlindAssignments",
    "preWitnessBlindReviewReceipts",
    "temporalAttestations",
    "evidenceIndex",
    "evidencePayloadSet",
    "approvedEvidenceAcquisitions",
    "evidenceAcquisitionReceipts",
    "evidenceAcquisitionEnvelopes",
    "acquisitionAuthoritySnapshot",
    "evidenceReceipts",
    "approvedSourceAcquisitions",
    "approvedSourceAcquisitionRounds",
    "sourceAcquisitionReceipts",
    "sourceAcquisitionRoundReceipts",
    "materializationReceipts",
    "normalizerRegistry",
    "overlapPolicy",
    "overlapUniverse",
    "overlapIndexReceipt",
    "overlapResourceReceipt",
    "overlapLedger",
    "privacyLedger",
    "qualityLedger",
    "lineageLedger",
    "preWitnessBundleSha256"
  ],
  "properties": {
    "version": { "const": "v10.3-admission-pre-witness-bundle-v1" },
    "policy": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-policy.schema.json" },
    "witnessPolicies": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-witness-policy.schema.json" },
        { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-witness-policy.schema.json" }
      ],
      "items": false
    },
    "toolProfiles": { "type": "array", "maxItems": 12, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-tool-profile.schema.json" } },
    "invocationIntents": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-invocation-intent.schema.json" } },
    "toolReceipts": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-tool-receipt.schema.json" } },
    "toolAuthoritySnapshot": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-tool-authority-snapshot.schema.json" },
    "sourceRegister": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-source-register.schema.json" },
    "registerDeltas": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-register-delta.schema.json" } },
    "registerGenerationReceipts": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-register-generation-receipt.schema.json" } },
    "sourceReviews": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-source-review.schema.json" } },
    "reviewSamples": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-review-sample.schema.json" } },
    "decisionLedgers": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-decision-ledger.schema.json" } },
    "admissionRecordStream": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-record-stream.schema.json" },
    "preWitnessDecisions": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-decision.schema.json" } },
    "preWitnessBlindAssignments": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-blind-assignment.schema.json" } },
    "preWitnessBlindReviewReceipts": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-blind-review-receipt.schema.json" } },
    "temporalAttestations": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-historical-temporal-attestation.schema.json" } },
    "evidenceIndex": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-evidence-index.schema.json" },
    "evidencePayloadSet": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-evidence-payload-set.schema.json" },
    "approvedEvidenceAcquisitions": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-approved-evidence-acquisition.schema.json" } },
    "evidenceAcquisitionReceipts": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-evidence-acquisition-receipt.schema.json" } },
    "evidenceAcquisitionEnvelopes": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-evidence-acquisition-envelope.schema.json" } },
    "acquisitionAuthoritySnapshot": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-acquisition-snapshot.schema.json" },
    "evidenceReceipts": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-evidence-receipt.schema.json" } },
    "approvedSourceAcquisitions": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-approved-acquisition.schema.json" } },
    "approvedSourceAcquisitionRounds": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-acquisition-round-authorization.schema.json" } },
    "sourceAcquisitionReceipts": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-acquisition-receipt.schema.json" } },
    "sourceAcquisitionRoundReceipts": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-acquisition-round-receipt.schema.json" } },
    "materializationReceipts": { "type": "array", "maxItems": 452382, "items": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-materialization-receipt.schema.json" } },
    "normalizerRegistry": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-normalizer-registry.schema.json" },
    "overlapPolicy": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-overlap-policy.schema.json" },
    "overlapUniverse": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-overlap-universe.schema.json" },
    "overlapIndexReceipt": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-overlap-index-receipt.schema.json" },
    "overlapResourceReceipt": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-overlap-resource-receipt.schema.json" },
    "overlapLedger": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-overlap-ledger.schema.json" },
    "privacyLedger": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-privacy-ledger.schema.json" },
    "qualityLedger": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-quality-ledger.schema.json" },
    "lineageLedger": { "$ref": "https://usebrick.dev/schemas/v1/calibration-admission-lineage-ledger.schema.json" },
    "preWitnessBundleSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
