{
  "name": "@usebrick/core",
  "version": "0.3.0",
  "private": true,
  "description": "Shared .slop-audit/ memory artifact reader/writer + Repository Memory Platform types. The contract every usebrick.dev tool depends on. Private to the monorepo — not published to npm until the schema is stable.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./verdicts": {
      "types": "./dist/verdicts.d.ts",
      "import": "./dist/verdicts.js",
      "require": "./dist/verdicts.cjs"
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "prebuild": "pnpm codegen && pnpm test:contract && tsup",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "node --import tsx scripts/codegen-types.ts",
    "test:contract": "node --import tsx scripts/verify-codegen-fresh.ts",
    "validate:schema": "node --import tsx scripts/validate-schemas.ts"
  },
  "keywords": [
    "usebrick",
    "repository-memory",
    "slopbrick",
    "slop-audit",
    "schema",
    "inventory",
    "constitution"
  ],
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "3.2.7",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "json-schema-to-typescript": "^15.0.4",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0",
    "vitest": "3.2.7"
  }
}
