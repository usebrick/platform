{
  "name": "@usebrick/website",
  "version": "0.14.5",
  "private": true,
  "type": "module",
  "description": "usebrick.dev marketing site. Brick-themed Astro site, no runtime deps beyond Astro itself.",
  "scripts": {
    "dev": "pnpm prebuild && astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "prebuild": "node --import tsx scripts/prebuild.ts",
    "astro": "astro",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest",
    "test:a11y": "playwright test",
    "test:a11y:ci": "playwright test"
  },
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.18.0",
    "astro": "7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/jsdom": "^28.0.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "3.2.7"
  }
}
