---
// Footer — minimal. The version is sourced from the prebuild
// script (`scripts/prebuild.ts`) which reads slopbrick's
// package.json so the two stay in sync.
import version from '../data/version.json';
---

<footer class="footer">
  <div class="footer__row">
    <a href="https://github.com/usebrick/platform" rel="noopener">github</a>
    <a href="https://www.npmjs.com/package/slopbrick" rel="noopener">npm</a>
    <a href="https://github.com/usebrick/platform/blob/main/LICENSE" rel="noopener">license</a>
    <a href="https://github.com/usebrick/platform/blob/main/CHANGELOG.md" rel="noopener">changelog</a>
  </div>
  <div>© usebrick — repository memory, one codebase at a time</div>
  <div class="footer__version">
    slopbrick <span>{version.slopbrick}</span> · core <span>{version.core}</span> · built {version.built}
  </div>
</footer>
