---
// RulesShowcase — 8 actual rules slopbrick ships with, displayed
// as a 2-column wall of "rule cards". Each card shows the rule's
// id, severity, a one-line rule shape (what it catches), and the
// per-rule P/R/FPR from the calibration corpus. The intent is to
// show the evidence-backed registry rather than a marketing-only count.

import productFacts from '../data/product-facts.json';

interface Rule {
  id: string;
  category: string;
  severity: 'high' | 'medium' | 'low';
  shape: string;
  precision: number;
  recall: number;
  fpr: number;
  defaultOff?: boolean;
  verdict?: string;
  aiOnly: boolean;
  /** v0.43.0 anti-AI: custom inline SVG icon name (no emojis).
   * Icons are monoline 1.5px stroke, 24x24 viewBox, currentColor. */
  icon: 'comment' | 'compress' | 'shield-x' | 'grid' | 'check-q' | 'terminal' | 'duplicate' | 'book-x';
}

/* v0.43.0 anti-AI: inline SVG icons for each rule. No emojis, no
   icon font, no external deps. Each icon is monoline 24x24 with
   currentColor stroke so it picks up the section label color. */
const ICONS: Record<Rule['icon'], string> = {
  'comment': '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="13" y2="17"/><circle cx="20" cy="17" r="2" fill="currentColor" opacity="0.4"/></svg>',
  'compress': '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="4" width="16" height="3" rx="0.5"/><rect x="4" y="10.5" width="16" height="3" rx="0.5"/><rect x="4" y="17" width="16" height="3" rx="0.5"/></svg>',
  'shield-x': '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>',
  'grid': '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="1"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><rect x="9" y="9" width="6" height="6" fill="currentColor" opacity="0.3"/></svg>',
  'check-q': '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="8 12 11 15 16 9"/></svg>',
  'terminal': '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="1.5"/><polyline points="7 9 10 12 7 15"/><line x1="13" y1="15" x2="17" y2="15"/></svg>',
  'duplicate': '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="13" height="13" rx="1"/><rect x="8" y="8" width="13" height="13" rx="1"/><line x1="8" y1="12" x2="21" y2="12" opacity="0.4"/></svg>',
  'book-x': '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h7a3 3 0 0 1 3 3v13a2 2 0 0 0-2-2H4z"/><path d="M20 4h-7a3 3 0 0 0-3 3v13a2 2 0 0 1 2-2h8z"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>',
};

const rules: Rule[] = [
  {
    id: 'ai/comment-ratio',
    category: 'ai',
    severity: 'medium',
    shape: 'Parser-backed comment-line ratio outside a calibrated band',
    precision: 0, recall: 0, fpr: 0,
    aiOnly: true,
    icon: 'comment',
  },
  {
    id: 'ai/compression-profile',
    category: 'ai',
    severity: 'low',
    shape: 'Gzip savings > 0.60 + low line-to-line NCD variation',
    precision: 0, recall: 0, fpr: 0,
    aiOnly: true,
    icon: 'compress',
  },
  {
    id: 'security/dangerous-cors',
    category: 'security',
    severity: 'medium',
    shape: 'AST-proven wildcard or reflective CORS configuration',
    precision: 0, recall: 0, fpr: 0,
    aiOnly: false,
    icon: 'shield-x',
  },
  {
    id: 'visual/spacing-scale-violation',
    category: 'visual',
    severity: 'medium',
    shape: 'Tailwind spacing value outside the declared scale',
    precision: 0, recall: 0, fpr: 0,
    aiOnly: false,
    icon: 'grid',
  },
  {
    id: 'test/weak-assertion',
    category: 'test',
    severity: 'medium',
    shape: 'Assertion has no equality, matcher, or meaningful check',
    precision: 0, recall: 0, fpr: 0,
    aiOnly: false,
    icon: 'check-q',
  },
  {
    id: 'ai/console-debug-storm',
    category: 'ai',
    severity: 'low',
    shape: '≥10 debug statements without a structured logger',
    precision: 0, recall: 0, fpr: 0,
    aiOnly: true,
    icon: 'terminal',
  },
  {
    id: 'dup/identical-block',
    category: 'dup',
    severity: 'medium',
    shape: '20 normalized code lines repeat across project files',
    precision: 0, recall: 0, fpr: 0,
    aiOnly: false,
    icon: 'duplicate',
  },
  {
    id: 'docs/stale-package-reference',
    category: 'docs',
    severity: 'medium',
    shape: 'Documentation references a package absent from package.json',
    precision: 0, recall: 0, fpr: 0,
    aiOnly: false,
    icon: 'book-x',
  },
];

for (const rule of rules) {
  const measured = productFacts.showcaseRules[rule.id as keyof typeof productFacts.showcaseRules];
  Object.assign(rule, measured ?? { defaultOff: false, verdict: 'unmeasured' });
}

function fmtPct(n: number): string { return (n * 100).toFixed(0) + '%'; }
function fmtFpr(n: number): string { return n < 0.01 ? '<1%' : fmtPct(n); }

function severityClass(s: Rule['severity']): string {
  return `rules-showcase__pill--${s}`;
}
---

<section class="section rules-showcase" id="rules">
  <header class="rules-showcase__head">
    <span class="rules-showcase__label">{productFacts.measuredRuleCount} historically measured candidate rules</span>
    <h2 class="rules-showcase__title">
      Evidence for <span class="rules-showcase__count">{productFacts.measuredRuleCount}</span> of{' '}
      <span class="rules-showcase__count">{productFacts.ruleCount}</span> candidate rules.
    </h2>
    <p class="rules-showcase__body">
      These cards show per-rule precision, recall, and false-positive rate
      from the historical {productFacts.corpusLabel} evidence snapshot. It covers{' '}
      {productFacts.measuredRuleCount} of the {productFacts.ruleCount} candidate{' '}
      rules; the remaining {productFacts.unmeasuredRuleCount} are unmeasured{' '}
      language rules. Default-off rules are labeled and do not affect scores
      until recalibrated or explicitly enabled. Metrics describe corpus
      association, not authorship proof.
    </p>
  </header>

  <div class="rules-showcase__grid">
    {rules.map((r) => (
      <article class="rules-showcase__card" data-rule={r.id}>
        <header class="rules-showcase__card-head">
          <span class="rules-showcase__icon" aria-hidden="true" set:html={ICONS[r.icon]}></span>
          <code class="rules-showcase__id">{r.id}</code>
          {r.aiOnly && <span class="rules-showcase__ai">AI</span>}
        </header>
        <p class="rules-showcase__shape">{r.shape}</p>
        <dl class="rules-showcase__metrics">
          <div class="rules-showcase__metric">
            <dt>precision</dt>
            <dd class="rules-showcase__metric--good">{fmtPct(r.precision)}</dd>
          </div>
          <div class="rules-showcase__metric">
            <dt>recall</dt>
            <dd class="rules-showcase__metric--good">{fmtPct(r.recall)}</dd>
          </div>
          <div class="rules-showcase__metric">
            <dt>FP rate</dt>
            <dd class="rules-showcase__metric--good">{fmtFpr(r.fpr)}</dd>
          </div>
        </dl>
        <span class={`rules-showcase__pill ${severityClass(r.severity)}`}>
          {r.severity}
        </span>
        {r.defaultOff && <span class="rules-showcase__pill rules-showcase__pill--off">default-off</span>}
      </article>
    ))}
  </div>
</section>
