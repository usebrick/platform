---
// Hero — eyebrow + title + subtitle + click-to-copy install.
// The WebGL canvas (BrickShader) is its background; the .hero
// class positions the content above it.
import BrickShader from './BrickShader.astro';
---

<header class="hero" id="top">
  <BrickShader />
  <div class="hero__content">
    <div class="hero__eyebrow">
      <span class="hero__eyebrow-dot"></span>
      <span>v0.15.0 — 4 tools, 60+ rules, 13 scores</span>
    </div>
    <h1 class="hero__title">
      A <em>repository structure</em> for your code.
    </h1>
    <p class="hero__subtitle">
      Detect, classify, and ship with confidence. usebrick.dev is a
      four-tool platform that turns an LLM-augmented codebase into a
      continuously-modeled codebase — one that knows its frameworks,
      its patterns, its smells, and the rules that catch them.
    </p>
    <button class="hero__install" data-copy="npm install -g slopbrick" aria-label="Copy install command">
      <span class="hero__install-prompt">$</span>
      <span class="hero__install-cmd">npm install -g slopbrick</span>
      <svg class="hero__install-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2" />
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
      </svg>
    </button>
  </div>
  <div class="hero__scroll">
    <span>scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</header>
