---
// Hero — the first (oversized) brick, but it now does real work.
// 2-column layout: brand/copy on the left, a live .slopbrick/
// artifact preview on the right. The preview rotates through the
// 4 files every 7s with a subtle cross-fade, so visitors see the
// real shape without leaving the page.
//
// Layout decisions:
// - .hero__content is grid-template-columns: 1fr 1.1fr so the
//   copy column gets ~45% and the preview column gets ~55%. The
//   preview has the live content (JSON + stats) and is more
//   visually dense, so it gets the extra room.
// - .hero__title has <br class="hero__title-break"> only on
//   wide viewports (display: block on >920px, display: none on
//   smaller). On mobile the title flows naturally.
// - .hero__facts is flex-wrap: wrap with row gap so the 4
//   short fact labels flow as pills and wrap on narrow.
import languageSupport from '../data/language-support.json';
---

<header class="hero" id="top">
  <div class="hero__wall" aria-hidden="true"></div>
  <div class="hero__grid-overlay" aria-hidden="true"></div>

  <div class="brick brick--hero brick--raised hero__brick">
    <div class="hero__content">
      <aside class="hero__copy">
        <span class="hero__eyebrow">
          <span class="hero__eyebrow-dot" aria-hidden="true"></span>
          v0.43.0 · 103 rules · 4 scores · 576k files
        </span>

        <h1 class="hero__title">
          A <span class="hero__title-accent">repository structure</span><br class="hero__title-break" />for your code.
        </h1>

        <p class="hero__subtitle">
          103 rules. v10-calibrated against <strong>576,750 files</strong>.
          v0.43.0 ships with the 4-score model, the MCP server, the
          Constitution engine, and per-rule precision/recall on disk.
        </p>

        <div class="hero__cta-row">
          <button
            class="hero__install"
            data-copy="npm install -g slopbrick"
            data-magnetic
            aria-label="Copy install command"
          >
            <span class="hero__install-prompt" aria-hidden="true">$</span>
            <span class="hero__install-cmd">npm install -g slopbrick</span>
            <svg
              class="hero__install-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="9" y="9" width="13" height="13" rx="2" />
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            </svg>
          </button>
          <a
            class="hero__secondary"
            href="https://github.com/usebrick/platform"
            rel="noopener"
            aria-label="View on GitHub"
          >
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
              <path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57v-2.02C6.7 21.6 6.1 19.6 6.1 19.6c-.55-1.4-1.35-1.77-1.35-1.77-1.1-.75.08-.74.08-.74 1.22.08 1.86 1.25 1.86 1.25 1.08 1.85 2.84 1.32 3.53 1 .1-.78.42-1.32.77-1.62-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.3-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .31.22.7.83.58A12 12 0 0 0 12 .3z" />
            </svg>
            <span>github</span>
          </a>
        </div>

        <ul class="hero__facts">
          <li class="hero__fact--live"><span class="hero__fact-dot" aria-hidden="true"></span><span>shipped</span> v0.43.0</li>
          <li><span>~1.1 MB</span> published tarball</li>
          <li><span>offline</span> first run</li>
          <li><span>MIT</span> license</li>
          <li><span>Node ≥ 20</span></li>
        </ul>
      </aside>

      <aside class="hero__terminal" aria-label="slopbrick scan in progress" aria-hidden="true">
        <header class="hero__terminal-bar">
          <div class="hero__terminal-dots">
            <span class="hero__terminal-dot"></span>
            <span class="hero__terminal-dot"></span>
            <span class="hero__terminal-dot"></span>
          </div>
          <span class="hero__terminal-path">~/your-repo</span>
          <span class="hero__terminal-pulse">
            <span class="hero__terminal-pulse-dot"></span>
            <span>scanning</span>
          </span>
        </header>
        <div class="hero__terminal-body">
          <span class="lt-line lt-line--echo"><span class="lt-prompt">$</span> <span class="lt-cmd">slopbrick scan</span></span>
          <span class="lt-line"></span>
          <span class="lt-line lt-line--output">  <span class="lt-k">AI Slop Score</span>          <span class="lt-v">25</span>  <span class="lt-b lt-b--good">low</span></span>
          <span class="lt-line lt-line--output">  <span class="lt-k">Engineering Hygiene</span>   <span class="lt-v">100</span>  <span class="lt-b lt-b--good">excellent</span></span>
          <span class="lt-line lt-line--output">  <span class="lt-k">Security</span>              <span class="lt-v">100</span>  <span class="lt-b lt-b--good">excellent</span></span>
          <span class="lt-line lt-line--output">  <span class="lt-k">Repository Health</span>    <span class="lt-v">57</span>  <span class="lt-b lt-b--mid">needs work</span></span>
          <span class="lt-line"></span>
          <span class="lt-line lt-line--success">  ✓ CI gate: 25 &lt;= 30 → pass</span>
          <span class="lt-line lt-line--muted">  0 issues · 593 files · 0.4s</span>
        </div>
        <footer class="hero__terminal-footer">
          <span class="hero__terminal-stat"><span class="hero__terminal-stat-n">593</span><span class="hero__terminal-stat-l">files</span></span>
          <span class="hero__terminal-stat"><span class="hero__terminal-stat-n">103</span><span class="hero__terminal-stat-l">rules</span></span>
          <span class="hero__terminal-stat"><span class="hero__terminal-stat-n">22</span><span class="hero__terminal-stat-l">categories</span></span>
          <span class="hero__terminal-stat"><span class="hero__terminal-stat-n">{languageSupport.count}</span><span class="hero__terminal-stat-l">language families</span></span>
        </footer>
      </aside>

    </div>
  </div>

  <div class="hero__scroll-hint" aria-hidden="true">
    <span>scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</header>
