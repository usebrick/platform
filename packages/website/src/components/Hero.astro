---
// Hero — the first (oversized) brick, but it now does real work.
// 2-column layout: brand/copy on the left, a live .slopbrick/
// artifact preview on the right. The preview rotates through the
// 4 files every 7s with a subtle cross-fade, so visitors see the
// real shape without leaving the page.
//
// Layout decisions:
// - .hero__content is grid-template-columns: 1fr 1.1fr so the
//   copy column gets ~45% and the preview column gets ~55%. The
//   preview has the live content (JSON + stats) and is more
//   visually dense, so it gets the extra room.
// - .hero__title has <br class="hero__title-break"> only on
//   wide viewports (display: block on >920px, display: none on
//   smaller). On mobile the title flows naturally.
// - .hero__facts is flex-wrap: wrap with row gap so the 4
//   short fact labels flow as pills and wrap on narrow.

---

<header class="hero" id="top">
  <div class="hero__wall" aria-hidden="true"></div>
  <div class="hero__grid-overlay" aria-hidden="true"></div>

  <div class="brick brick--hero brick--raised hero__brick">
    <div class="hero__content">
      <aside class="hero__copy">
        <span class="hero__eyebrow">
          <span class="hero__eyebrow-dot" aria-hidden="true"></span>
          v0.43.0 · 103 rules · 4 scores · 576k files
        </span>

        <h1 class="hero__title">
          A <span class="hero__title-accent">repository structure</span><br class="hero__title-break" />for your code.
        </h1>

        <p class="hero__subtitle">
          Detect, classify, ship. usebrick.dev turns an LLM-augmented
          codebase into one that knows its frameworks, patterns,
          smells, and the rules that catch them.
        </p>

        <div class="hero__cta-row">
          <button
            class="hero__install"
            data-copy="npm install -g slopbrick"
            data-magnetic
            aria-label="Copy install command"
          >
            <span class="hero__install-prompt" aria-hidden="true">$</span>
            <span class="hero__install-cmd">npm install -g slopbrick</span>
            <svg
              class="hero__install-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="9" y="9" width="13" height="13" rx="2" />
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            </svg>
          </button>
          <a
            class="hero__secondary"
            href="https://github.com/usebrick/platform"
            rel="noopener"
            aria-label="View on GitHub"
          >
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
              <path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57v-2.02C6.7 21.6 6.1 19.6 6.1 19.6c-.55-1.4-1.35-1.77-1.35-1.77-1.1-.75.08-.74.08-.74 1.22.08 1.86 1.25 1.86 1.25 1.08 1.85 2.84 1.32 3.53 1 .1-.78.42-1.32.77-1.62-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.3-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .31.22.7.83.58A12 12 0 0 0 12 .3z" />
            </svg>
            <span>github</span>
          </a>
        </div>

        <ul class="hero__facts">
          <li><span>~150 kB</span> tarball</li>
          <li><span>offline</span> first run</li>
          <li><span>MIT</span> license</li>
          <li><span>Node ≥ 20</span></li>
        </ul>
      </aside>

      <aside class="hero__preview" data-hero-preview aria-hidden="true">
        <header class="hero__preview-bar">
          <span class="hero__preview-dot"></span>
          <span class="hero__preview-dot"></span>
          <span class="hero__preview-dot"></span>
          <span class="hero__preview-path" data-hero-path></span>
        </header>
        <div class="hero__preview-body" data-hero-body></div>
      </aside>
    </div>
  </div>

  <div class="hero__scroll-hint" aria-hidden="true">
    <span>scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</header>

<script>
  // Hero preview rotator — no framework, just toggling the data-* attributes.
  // Cycles through 4 .slopbrick/ artifacts every 7s with a subtle cross-fade.
  document.querySelectorAll<HTMLElement>('[data-hero-preview]').forEach((root) => {
    const pathEl = root.querySelector<HTMLElement>('[data-hero-path]');
    const bodyEl = root.querySelector<HTMLElement>('[data-hero-body]');
    const statsEl = root.querySelector<HTMLElement>('[data-hero-stats]');

    type Frame = {
      path: string;
      json: Record<string, unknown>;
      stats: Array<[string, string, 'good' | 'mid' | 'bad']>;
    };
    const FRAMES: Frame[] = [
      {
        path: '~/your-repo/.slopbrick/health.json',
        json: {
          aiSlopScore: 25,
          engineeringHygiene: 100,
          security: 100,
          repositoryHealth: 57,
        },
        stats: [
          ['AI Slop Score', 'low', 'good'],
          ['Engineering Hygiene', 'consistent', 'good'],
          ['Security', 'no AI-flagged risks', 'good'],
          ['Repository Health', 'composite (hierarchy + security)', 'mid'],
        ],
      },
      {
        path: '~/your-repo/.slopbrick/inventory.json',
        json: {
          files: 593,
          patterns: { modal: 4, button: 6, 'data-fetch': 8, state: 3 },
          components: 312,
        },
        stats: [
          ['Patterns (modal)', '4 — vanilla.css', 'good'],
          ['Patterns (state)', '3 — zustand', 'good'],
          ['Patterns (data-fetch)', '8 — swr', 'good'],
          ['Components', '312 components', 'good'],
        ],
      },
      {
        path: '~/your-repo/.slopbrick/constitution.json',
        json: {
          stateManagement: 'zustand',
          dataFetching: 'swr',
          uiLibrary: 'shadcn/ui',
          forbidden: ['chart.js', 'redux'],
        },
        stats: [
          ['stateManagement', 'zustand ✓', 'good'],
          ['dataFetching', 'swr ✓', 'good'],
          ['forbidden (chart.js)', 'blocked — drifts exits 1', 'good'],
          ['Match against repo', '0 violations', 'good'],
        ],
      },
      {
        path: '~/your-repo/.slopbrick/structure.md',
        json: {
          section: 'Patterns',
          counts: { 'state libs': 1, 'fetch libs': 1, modals: 1, 'API clients': 1 },
        },
        stats: [
          ['Patterns (state)', '1 canonical — zustand', 'good'],
          ['Patterns (fetch)', '1 canonical — swr', 'good'],
          ['Patterns (modals)', '1 canonical — radix', 'good'],
          ['Patterns (api)', '1 canonical — openapi-fetch', 'good'],
        ],
      },
    ];

    let i = 0;
    const render = (frame: Frame) => {
      if (pathEl) pathEl.textContent = frame.path;
      // The preview shows the user-facing rendering (the stats
      // grid that lives in any HTML slopbrick generates) — NOT the
      // raw .slopbrick/health.json shape. Users don't need to see
      // internal field names like "aiSlopScore" — they need the
      // verdict: low / consistent / no AI-flagged risks / etc.
      if (bodyEl) {
        bodyEl.innerHTML = frame.stats
          .map(([k, v, c]) =>
            `<div class="hero__preview-stat hero__preview-stat--${c}">
              <span class="hero__preview-stat-key">${escapeHtml(k)}</span>
              <span class="hero__preview-stat-val">${escapeHtml(v)}</span>
            </div>`
          )
          .join('');
      }
      if (statsEl) {
        statsEl.innerHTML = frame.stats
          .map(([k, v, c]) =>
            `<li class="hero__preview-stat hero__preview-stat--${c}"><span class="hero__preview-stat-key">${escapeHtml(k)}</span><span class="hero__preview-stat-val">${escapeHtml(v)}</span></li>`
          )
          .join('');
      }
    };
    const escapeHtml = (s: string): string =>
      s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');

    render(FRAMES[0]!);
    setInterval(() => {
      i = (i + 1) % FRAMES.length;
      render(FRAMES[i]!);
    }, 7000);
  });
</script>
