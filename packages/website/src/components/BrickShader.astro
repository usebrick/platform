---
// BrickShader — the full-bleed WebGL canvas behind the hero.
// Renders a procedural brick wall; initialized by an inline
// script that hydrates the canvas on page load.
---

<div class="hero__canvas" id="brick-canvas-wrap">
  <canvas id="brick-canvas" aria-hidden="true"></canvas>
  <picture>
    <img src="/brick-pattern.svg" alt="" />
  </picture>
</div>

<script>
  import { initBrickShader } from '../scripts/brick-shader';
  import { isLowPower } from '../scripts/low-power';
  const canvas = document.getElementById('brick-canvas') as HTMLCanvasElement | null;
  const wrap = document.getElementById('brick-canvas-wrap');
  if (canvas && wrap) {
    if (isLowPower()) {
      canvas.style.display = 'none';
      wrap.querySelector('picture')!.style.display = 'block';
    } else {
      initBrickShader(canvas);
    }
  }
</script>
