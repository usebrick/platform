---
// Nav — a single brick at the top. Translucent so the hero
// shows through, but the brick shape is the only way to render
// it. The user sees: nav brick, hero brick, wall continues.
import Logo from './Logo.astro';
---

<nav class="nav" aria-label="Primary">
  <div class="brick brick--nav">
    <Logo size="sm" />
    <span class="nav__version" aria-label="Latest version">v0.43.0</span>
    <div class="nav__links">
      <a href="#tools">platform</a>
      <a href="#compare">diff vs linters</a>
      <a href="#calibration">the 4 scores</a>
      <a href="https://github.com/usebrick/platform" rel="noopener">github</a>
    </div>
  </div>
</nav>
