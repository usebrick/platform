---
// Tools — the usebrick product ladder. Each card states whether the
// layer is shipped, substrate, next, or later so roadmap work never
// appears as a current product claim.

import BrickLayout from './BrickLayout.astro';
import productFacts from '../data/product-facts.json';

interface Tool {
  name: string;
  label: string;
  desc: string;
  icon: 'cli' | 'mcp' | 'schemas' | 'constitution';
  /** v0.43.0 editorial layout: the CLI is the main entry point,
   *  so it gets the featured treatment (spans both columns). */
  featured?: boolean;
}

const tools: Tool[] = [
  {
    name: 'slopbrick',
    label: 'SCAN · SHIPPED',
    desc: `The free front door for vibecoders: scan locally, inspect four scores, and act on file-level evidence. v${productFacts.published.version} publishes ${productFacts.published.ruleCount} rules in ${productFacts.published.categoryCount} categories.`,
    icon: 'cli',
    featured: true,
  },
  {
    name: 'memorybrick',
    label: 'REMEMBER · SUBSTRATE',
    desc: 'Repository-owned observed facts, declared policy, health, and concise agent context. Existing artifacts and MCP access are the foundation; provenance and freshness are the next contract.',
    icon: 'mcp',
  },
  {
    name: 'lockbrick',
    label: 'PROTECT · NEXT',
    desc: 'The first paid team layer: fail new architectural drift and stale policy in CI without requiring a repository-wide cleanup first.',
    icon: 'schemas',
  },
  {
    name: 'mendbrick',
    label: 'REPAIR · LATER',
    desc: 'Deterministic, reversible repair for findings teams already trust. Pick is folded into init and policy authoring instead of marketed as another product.',
    icon: 'constitution',
  },
];
---

<section class="section tools" id="tools">
  <div class="brick-wall tools__wall">
    <BrickLayout as="header" tone="raised" class="tools__head" span={2}>
      <div class="tools__head-inner">
        <span class="tools__label">one product, a clear adoption ladder</span>
        <h2 class="tools__title">Scan first. <span class="tools__title-accent">Protect what works.</span></h2>
        <p class="tools__body">
          SlopBrick is the shipped front door. Repository-owned memory makes findings contextual.
          LockBrick turns trusted rules into team policy. MendBrick follows only with safe repair.
          The roadmap never turns a planned layer into a shipped claim.
        </p>
      </div>
    </BrickLayout>

    {tools.map((t) => (
      <BrickLayout
        as="article"
        tone="default"
        class={`tools__brick tools__brick--${t.icon}${t.featured ? ' tools__brick--featured' : ''}`}
        data-tool={t.icon}
        span={t.featured ? 2 : 1}
      >
        <article
          class="tool-card"
          role="button"
          tabindex="0"
          aria-label={`Crack the ${t.label} brick`}
        >
          <svg class="tool-card__icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            {t.icon === 'cli' && (
              <>
                <polyline points="4 17 10 11 4 5" />
                <line x1="12" y1="19" x2="20" y2="19" />
              </>
            )}
            {t.icon === 'mcp' && (
              <>
                <rect x="3" y="6" width="18" height="12" rx="2" />
                <path d="M7 10h.01M11 10h.01M15 10h.01M7 14h10" />
              </>
            )}
            {t.icon === 'schemas' && (
              <>
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="9" y1="13" x2="15" y2="13" />
                <line x1="9" y1="17" x2="13" y2="17" />
              </>
            )}
            {t.icon === 'constitution' && (
              <>
                <path d="M12 2l3 6 6 1-4.5 4.5L18 20l-6-3-6 3 1.5-6.5L3 9l6-1z" />
              </>
            )}
          </svg>
          <h3 class="tool-card__label">{t.label}</h3>
          <p class="tool-card__name">{t.name}</p>
          <p class="tool-card__desc">{t.desc}</p>
          <span class="tool-card__hint">click to crack</span>
          <svg class="tool-card__cracks" viewBox="0 0 280 160" preserveAspectRatio="none" aria-hidden="true">
            <line class="tool-card__crack" x1="140" y1="80" x2="140" y2="80" />
            <line class="tool-card__crack" x1="140" y1="80" x2="140" y2="80" />
            <line class="tool-card__crack" x1="140" y1="80" x2="140" y2="80" />
          </svg>
        </article>
      </BrickLayout>
    ))}
  </div>
</section>
