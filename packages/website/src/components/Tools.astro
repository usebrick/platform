---
// Tools — the slopbrick platform, broken into its surfaces.
// 4 cards: CLI · MCP · JSON Schemas · Constitution. Each is a
// real, shipped capability, not vaporware. (pickbrick/mendbrick
// were "Planned" cards that looked unprofessional; removed in
// v0.43.0 polish.)

import BrickLayout from './BrickLayout.astro';

const tools = [
  {
    name: 'cli',
    label: 'CLI',
    desc: 'Score code on 4 axes. Writes .slopbrick/ artifacts. v0.43.0, 103 rules across 22 categories, v10-calibrated against 576,750 files.',
    icon: 'cli' as const,
  },
  {
    name: 'mcp',
    label: 'MCP',
    desc: 'Talk to Claude Code, Cursor, Copilot. 5 tools, JSON-RPC 2.0 over stdio. Agents consume the structure, not the AST.',
    icon: 'mcp' as const,
  },
  {
    name: 'schemas',
    label: 'JSON Schemas',
    desc: '4 contracts: Inventory, Constitution, Structure, Health. The wire format every agent and dashboard agrees on. Cross-language.',
    icon: 'schemas' as const,
  },
  {
    name: 'constitution',
    label: 'Constitution',
    desc: 'Declare your stack once in slopbrick.config.mjs. The agent + linter enforce it together. Drift is an exit code.',
    icon: 'constitution' as const,
  },
];
---

<section class="section tools" id="tools">
  <div class="brick-wall tools__wall">
    <BrickLayout as="header" tone="raised" class="tools__head" span={2}>
      <div class="tools__head-inner">
        <span class="tools__label">the platform</span>
        <h2 class="tools__title">One product. <span class="tools__title-accent">Four surfaces.</span></h2>
        <p class="tools__body">
          slopbrick ships as a CLI, an MCP server, four JSON Schemas, and a Constitution engine.
          Every surface reads and writes the same <code>.slopbrick/</code> artifacts — so
          the agent and your CI agree on what they're seeing.
        </p>
      </div>
    </BrickLayout>

    {tools.map((t) => (
      <BrickLayout
        as="article"
        tone="default"
        class={`tools__brick tools__brick--${t.icon}`}
        data-tool={t.icon}
      >
        <article
          class="tool-card"
          role="button"
          tabindex="0"
          aria-label={`Crack the ${t.label} brick`}
        >
          <svg class="tool-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            {t.icon === 'cli' && (
              <>
                <polyline points="4 17 10 11 4 5" />
                <line x1="12" y1="19" x2="20" y2="19" />
              </>
            )}
            {t.icon === 'mcp' && (
              <>
                <rect x="3" y="6" width="18" height="12" rx="2" />
                <path d="M7 10h.01M11 10h.01M15 10h.01M7 14h10" />
              </>
            )}
            {t.icon === 'schemas' && (
              <>
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="9" y1="13" x2="15" y2="13" />
                <line x1="9" y1="17" x2="13" y2="17" />
              </>
            )}
            {t.icon === 'constitution' && (
              <>
                <path d="M12 2l3 6 6 1-4.5 4.5L18 20l-6-3-6 3 1.5-6.5L3 9l6-1z" />
              </>
            )}
          </svg>
          <h3 class="tool-card__label">{t.label}</h3>
          <p class="tool-card__name">{t.name}</p>
          <p class="tool-card__desc">{t.desc}</p>
          <span class="tool-card__hint">click to crack</span>
          <svg class="tool-card__cracks" viewBox="0 0 280 160" preserveAspectRatio="none" aria-hidden="true">
            <line class="tool-card__crack" x1="140" y1="80" x2="140" y2="80" />
            <line class="tool-card__crack" x1="140" y1="80" x2="140" y2="80" />
            <line class="tool-card__crack" x1="140" y1="80" x2="140" y2="80" />
          </svg>
        </article>
      </BrickLayout>
    ))}
  </div>
</section>
