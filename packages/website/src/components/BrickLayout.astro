---
// BrickLayout — primitive that renders a brick-shaped cell.
// The page is built from these: every section, every card, every
// terminal is a brick. A `.brick-wall` parent offsets alternating
// rows by half a brick-width (the running-bond pattern), so the
// whole layout reads as a real masonry wall.
//
// The component is just a wrapper. The visual is driven by CSS
// (`.brick` + `.brick-wall` in components.css). This keeps the
// component trivial and lets the wall be composed in markup.

interface Props {
  /** Optional accessible label for the brick. */
  ariaLabel?: string;
  /** Optional CSS class added to the brick. */
  class?: string;
  /** Render as a different element (e.g. 'section', 'article'). */
  as?: 'div' | 'section' | 'article' | 'aside' | 'header' | 'footer';
  /** Span multiple columns in a `.brick-wall` grid. */
  span?: 1 | 2 | 3;
  /** Span multiple rows in a `.brick-wall` grid. */
  rowSpan?: 1 | 2;
  /** Visual treatment. */
  tone?: 'default' | 'raised' | 'recessed' | 'accent' | 'muted' | 'cracked';
  /** When true, the brick is interactive (hover/active states). */
  interactive?: boolean;
  /** When true, render an extra thick left edge to read as a "header brick". */
  headBrick?: boolean;
}
const {
  ariaLabel,
  class: className = '',
  as: Tag = 'div',
  span,
  rowSpan,
  tone = 'default',
  interactive = false,
  headBrick = false,
} = Astro.props;

const classes = [
  'brick',
  `brick--${tone}`,
  headBrick ? 'brick--head' : '',
  interactive ? 'brick--interactive' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const styleAttr = [
  span ? `--brick-col: span ${span};` : '',
  rowSpan ? `--brick-row: span ${rowSpan};` : '',
]
  .filter(Boolean)
  .join(' ');
---

<Tag class={classes} style={styleAttr || undefined} aria-label={ariaLabel}>
  <slot />
</Tag>
