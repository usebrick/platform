---
// Calibration — the four numbers that earn the "usebrick" name.
// Count-up animation on reveal (counter.ts). Each stat shows:
// - The actual score (e.g. 25) with band label (e.g. "low")
// - A one-line brief explanation of what the score measures
// - A natural-language verdict (e.g. "low amount of AI slop")
//
// From `slopbrick scan --workspace packages/slopbrick --brief` on 2026-07-06.
// Shape: aiSlopScore=25, engineeringHygiene=100, security=100, repositoryHealth=57.
// The slopbrick repo's meanSlop is 15 (strict self-scan threshold).
//
// v0.21.0: aiSlopScore is raw amount of slop (lower = cleaner), not
// the inverted cleanliness reading. The 4 numbers below are the
// slopbrick repo's own historical self-scan — a real example, not
// current release-gate evidence or a cherry-picked marketing number.

import StructureDemo from './StructureDemo.astro';

// 4 stats with: number target, band label, brief explanation,
// verdict text, severity class.
const stats = [
  {
    target: 25,
    band: 'low',
    bandClass: 'good' as const,
    name: 'AI Slop Score',
    brief: 'raw amount of AI slop, 0-100',
    verdict: 'low amount of AI slop',
  },
  {
    target: 100,
    band: 'excellent',
    bandClass: 'good' as const,
    name: 'Engineering Hygiene',
    brief: 'cross-category consistency, 0-100',
    verdict: 'consistent across 6 categories',
  },
  {
    target: 100,
    band: 'excellent',
    bandClass: 'good' as const,
    name: 'Security',
    brief: 'AI Security Risk band, 0-100',
    verdict: 'no AI-flagged security risks',
  },
  {
    target: 57,
    band: 'needs work',
    bandClass: 'mid' as const,
    name: 'Repository Health',
    brief: 'weighted composite, 0-100',
    verdict: 'composite, hierarchy + security-weighted',
  },
];
---

<section class="section calibration" id="calibration">
  <header class="calibration__head">
    <span class="calibration__label">calibrated, not guessed</span>
    <h2 class="calibration__title">
      The numbers that earn the name <span class="calibration__accent">usebrick</span>.
    </h2>
    <p class="calibration__subhead">
      Historical example from <code>slopbrick scan</code> on this site&apos;s own repo,
      captured 2026-07-06; these values are not current release-gate evidence.
      Per-rule calibration lives in <code>src/rules/signal-strength.json</code>;
      measured rules carry historical v10.1 precision/recall evidence from
      576,750 analyzed files; 16 workspace rules remain unmeasured and
      default-off while v10.3 admission is pending.
    </p>
  </header>

  <div class="calibration__stats">
    {stats.map((s) => (
      <div class={`calibration__stat calibration__stat--${s.bandClass}`}>
        <div class="calibration__value-wrap">
          <span class="calibration__value" data-target={s.target} data-prefix="" data-suffix="">{s.target}</span>
          <span class="calibration__band">{s.band}</span>
        </div>
        <div class="calibration__axis">{s.name}</div>
        <div class="calibration__brief">{s.brief}</div>
        <div class="calibration__verdict">{s.verdict}</div>
      </div>
    ))}
  </div>

  <StructureDemo />

  <blockquote class="calibration__quote">
    Measured rules carry historical recall/FP evidence. A rule that fires more
    noise than signal, or has no approved calibration, stays <em>defaultOff</em>
    until it earns its way on. <strong>aiSlopScore</strong> uses the natural-reading
    direction (0 = clean, 100 = saturated) — the other three scores
    are &quot;higher = better&quot;.
    <cite class="calibration__cite">the usebrick calibration contract</cite>
  </blockquote>
</section>
