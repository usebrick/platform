---
// ToolCard — one of the 4 tool cards in the tools section.
// The card has a single SVG with 3 <line> children used by
// break-on-hover.ts to render the crack animation. Coordinates
// are set by JS on click; lines are zero-length by default.
interface Props {
  name: string;
  desc: string;
  icon: 'pickbrick' | 'mendbrick' | 'slopbrick' | 'core';
}
const { name, desc, icon } = Astro.props;
---

<article class="tool-card" data-tool={name}>
  <svg class="tool-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    {icon === 'pickbrick' && (
      <>
        <path d="M3 6h18l-2 12H5L3 6z" />
        <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
        <line x1="9" y1="11" x2="15" y2="11" />
      </>
    )}
    {icon === 'mendbrick' && (
      <>
        <path d="M14 7l3-3 3 3-3 3-3-3z" />
        <path d="M10 14l-3 3 3 3 3-3-3-3z" />
        <line x1="13" y1="10" x2="11" y2="14" />
      </>
    )}
    {icon === 'slopbrick' && (
      <>
        <path d="M4 17l6-6 4 4 6-6" />
        <path d="M14 9h6v6" />
        <circle cx="6" cy="6" r="1" fill="currentColor" />
      </>
    )}
    {icon === 'core' && (
      <>
        <rect x="3" y="3" width="7" height="7" />
        <rect x="14" y="3" width="7" height="7" />
        <rect x="3" y="14" width="7" height="7" />
        <rect x="14" y="14" width="7" height="7" />
      </>
    )}
  </svg>
  <h3 class="tool-card__name">{name}</h3>
  <p class="tool-card__desc">{desc}</p>
  <svg class="tool-card__cracks" viewBox="0 0 280 160" preserveAspectRatio="none" aria-hidden="true">
    <line class="tool-card__crack" x1="140" y1="80" x2="140" y2="80" />
    <line class="tool-card__crack" x1="140" y1="80" x2="140" y2="80" />
    <line class="tool-card__crack" x1="140" y1="80" x2="140" y2="80" />
  </svg>
</article>
