---
// Compare — slopbrick vs "everything else" (pre-2026 status quo).
// Side-by-side courses of bricks separated by a centered VS divider.
// The yay bricks are warm-toned (orange check); the nay bricks are
// cold-toned with line-through (struck-through old ways). Each
// section is a "course" in the wall — the masonry aesthetic carries
// the visual metaphor.

import BrickLayout from './BrickLayout.astro';
import productFacts from '../data/product-facts.json';
import version from '../data/version.json';

// "What slopbrick does" — 5 concrete capabilities you can verify
// in the docs and the CLI output.
const yay = [
  `Published v${productFacts.published.version}: ${productFacts.published.ruleCount} rules in ${productFacts.published.categoryCount} categories and four headline scores`,
  'Writes inventory.json, constitution.json, health.json, and derived structure.md; structure.json is separate local run history',
  'Local CLI and MCP surfaces expose portable evidence without requiring a hosted account',
  'Repository policy can turn selected, trusted findings into deterministic exit codes',
  `Historical ${productFacts.corpusLabel} evidence covers ${productFacts.measuredRuleCount} rules and ${productFacts.corpusAnalyzedFiles.toLocaleString()} analyzed files; v10.3 admission remains separate`,
];

// "What the alternative looks like" — the situation slopbrick replaces.
const nay = [
  'Generic findings with no repository-specific evidence or baseline',
  'Gates that require all historical debt to be fixed before adoption',
  'Each coding agent rediscovering conventions from scratch',
  'Opaque quality scores with no rule-level explanation',
  'Planned features presented as if they already ship',
];
---

<section class="section compare-section" id="compare">
  <BrickLayout as="header" tone="raised" class="compare-section__head" span={2}>
    <span class="compare-section__label">usebrick vs the rest</span>
    <h2 class="compare-section__title">
      Find new slop before it becomes <span class="compare-section__accent">repository debt</span>.
    </h2>
    <p class="compare-section__body">
      Start with the published scanner and four scores: AI Slop, Engineering Hygiene, Security,
      and Repository Health. The unreleased v{version.slopbrick} workspace candidate has
      {productFacts.ruleCount} rules across {productFacts.categoryCount} categories. Its repository
      artifacts make evidence reviewable; native agent adapters and paid enforcement remain roadmap work.
    </p>
  </BrickLayout>

  <div class="compare">
    <div class="compare__col compare__col--yay">
      <div class="compare__heading compare__heading--yay">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12" />
        </svg>
        <span>usebrick</span>
      </div>
      <div class="compare__items">
        {yay.map((line) => (
          <div class="compare__item">
            <span class="compare__check">
              <svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </span>
            <span class="compare__item-text">{line}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="compare__divider" aria-hidden="true">
      <span>vs</span>
    </div>

    <div class="compare__col compare__col--nay">
      <div class="compare__heading compare__heading--nay">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
        <span>everything else</span>
      </div>
      <div class="compare__items">
        {nay.map((line) => (
          <div class="compare__item compare__item--struck">
            <span class="compare__cross">
              <svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
            </span>
            <span class="compare__item-text">{line}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
