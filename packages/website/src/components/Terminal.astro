---
// Terminal — a fake terminal preview showing the install + run
// sequence. The terracotta prompt is the visual anchor of the
// site. The `t-prompt` token echoes the brick color.
---

<div class="terminal" role="img" aria-label="Terminal preview">
  <div class="terminal__bar">
    <span class="terminal__dot terminal__dot--r"></span>
    <span class="terminal__dot terminal__dot--y"></span>
    <span class="terminal__dot terminal__dot--g"></span>
    <span class="terminal__title">~ /your-repo</span>
  </div>
  <div class="terminal__body">
    <div class="terminal__line">
      <span class="terminal__prompt">$</span>
      <span class="terminal__cmd">npm install -g slopbrick</span>
    </div>
    <div class="terminal__line">
      <span class="terminal__out terminal__out--ok">+ slopbrick@0.14.5</span>
    </div>
    <div class="terminal__line">
      <span class="terminal__out">added 1 package in 1.4s</span>
    </div>
    <div class="terminal__line">
      <span class="terminal__prompt">$</span>
      <span class="terminal__cmd">slopbrick scan .</span>
    </div>
    <div class="terminal__line">
      <span class="terminal__out">scanning 287 files...</span>
    </div>
    <div class="terminal__line">
      <span class="terminal__out">detected: next.js 14, prisma 5, tanstack-query 5</span>
    </div>
    <div class="terminal__line">
      <span class="terminal__out">60 rules · 13 scores · 4 categories</span>
    </div>
    <div class="terminal__line">
      <span class="terminal__out terminal__out--ok">✓ health: 87/100 (good)</span>
    </div>
  </div>
</div>
