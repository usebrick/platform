---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
---

<Base title="Page not found — usebrick.dev" description="The requested usebrick.dev page does not exist.">
  <main id="top" class="error-page">
    <section class="error-page__card brick brick--raised" aria-labelledby="error-title">
      <Logo size="md" />
      <p class="error-page__code">404 / not found</p>
      <h1 id="error-title">That brick is not here.</h1>
      <p>The requested page does not exist. Return to the landing page or open the canonical documentation.</p>
      <div class="error-page__actions">
        <a class="btn btn--primary" href="/">Back to usebrick.dev</a>
        <a class="btn" href="/docs">Read the docs</a>
      </div>
    </section>
  </main>
</Base>

<style>
  .error-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: var(--space-8);
  }
  .error-page__card {
    width: min(100%, 46rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: clamp(2rem, 6vw, 5rem);
  }
  .error-page__code {
    color: var(--text-accent);
    font: 600 0.8rem/1 var(--font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .error-page h1 {
    font: 600 clamp(2.3rem, 7vw, 5rem)/1.05 var(--font-display);
  }
  .error-page p:not(.error-page__code) {
    max-width: 52ch;
    color: var(--text-secondary);
  }
  .error-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
</style>
