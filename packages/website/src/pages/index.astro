---
// index.astro — the only page in the site.
// The page is one brick wall. Each section is a course of bricks.
// The hero is the first (oversized) brick; the CTA is the last
// (largest) brick. Everything in between is masonry.

import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Scoreboard from '../components/Scoreboard.astro';
import Tools from '../components/Tools.astro';
import LiveTerminal from '../components/LiveTerminal.astro';
import RulesShowcase from '../components/RulesShowcase.astro';
import Compare from '../components/Compare.astro';
import Calibration from '../components/Calibration.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Nav />
  <main class="wall">
    <Hero />
    <Scoreboard />
    <Tools />
    <LiveTerminal />
    <RulesShowcase />
    <Compare />
    <Calibration />
    <CTASection />
  </main>
  <Footer />
</Base>
