---
// Base layout — document shell, global scripts, design tokens.
// Component scripts (counter, copy-install, break-on-hover) are
// wired here so they run on every page.
import '../styles/global.css';
import '../styles/theme.css';
import '../styles/components.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'usebrick.dev — repository structure for your code',
  description = 'A four-tool platform that continuously models and governs your repository\'s structure. Detect, classify, ship with confidence.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://usebrick.dev" />
    <meta property="og:image" content="https://usebrick.dev/og-image.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://usebrick.dev/og-image.svg" />
    <meta name="theme-color" content="#1a0e08" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-to-content" href="#top">Skip to content</a>
    <slot />

    <script>
      import { initCounters } from '../scripts/counter';
      import { initCopyInstall } from '../scripts/copy-install';
      import { initBreakOnHover } from '../scripts/break-on-hover';
      import { initStructureDemo } from '../scripts/structure-demo';
      import { initLiveTerminal } from '../scripts/live-terminal';

      const start = () => {
        initCounters();
        initCopyInstall();
        initBreakOnHover();
        initStructureDemo();
        initLiveTerminal();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', start, { once: true });
      } else {
        start();
      }
    </script>
  </body>
</html>
