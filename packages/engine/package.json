{
  "name": "@usebrick/engine",
  "version": "0.14.5",
  "private": true,
  "description": "Scanning engine with pure parsing/scoring APIs and explicit filesystem adapters. Reusable from CLI, MCP, and future web IDEs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pure": {
      "types": "./dist/pure.d.ts",
      "import": "./dist/pure.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.examples.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@swc/core": "^1.10.0",
    "@usebrick/core": "workspace:*",
    "globby": "^14.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5",
    "typescript": "^5.6",
    "vitest": "^2.1"
  }
}
