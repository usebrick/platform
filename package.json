{
  "name": "usebrick-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for the usebrick.dev platform — slopbrick CLI + shared @usebrick/core schema. Each package has its own release cadence; this root package is a workspace hub.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "security:audit": "node scripts/audit-npm-bulk.mjs --audit-level high",
    "scan": "node packages/slopbrick/bin/slopbrick.js scan",
    "bench:scan": "pnpm --filter slopbrick bench:scan",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-website-version.js"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "vitest>vite": "6.4.3",
      "vite-node>vite": "6.4.3",
      "yaml-language-server>yaml": "2.8.3",
      "tsup>esbuild": "0.28.1"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0"
  }
}
