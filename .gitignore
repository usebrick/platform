# Dependencies
node_modules/

# Local package tarballs (from pnpm pack / npm pack)
slopbrick-*.tgz
packages/slopbrick/slopbrick-*.tgz

# Build output
dist/

# Agent session / cache
.worktrees/
.kimi-code/
# Kimi session exports accidentally committed in v0.39.0; sweep the
# pattern so future exports stay out of the tree. Matches the
# `kimi-export-session_<ts>.md` shape produced by the Kimi CLI's
# session-export command. Untracked on disk; never `git add` these.
kimi-export-session_*.md
*.kimi-session.md
.slopbrick/
.slopbrick-cache.json

# Local corpus reference — contains absolute paths + repo lists that are
# private to each maintainer's machine. Commit the .template.json sibling
# instead; copy + fill in to create the .local.json.
**/corpus-manifest.local.json

# Test caches
.pytest_cache/

# OS / editor
.DS_Store
*.log
*.tsbuildinfo

# ── Operator-only / internal docs ──────────────────────────────────
# These are kept on the maintainer's local machine for reference
# but never tracked. Public visitors don't need them; the maintainer
# does. Add to this list (instead of deleting the file) when a doc
# is too specific to the current maintainer's workflow to be useful
# to a cloner, user, or contributor.

# Setup runbooks and operator how-tos
docs/operations/

# Internal AI-agent plans and design specs (superpowers)
docs/superpowers/

# Pre-launch marketing copy, draft blog posts, Show HN drafts
packages/slopbrick/Show HN post draft.md
packages/slopbrick/docs/launch-blog-post-*.md
packages/slopbrick/docs/website-copy-*.md

# Internal scoring / dev runbooks
packages/slopbrick/docs/experiment-findings.md
packages/slopbrick/docs/framework-parity-matrix.md
packages/slopbrick/docs/rename-checklist.md
packages/slopbrick/docs/pre-commit.md

# Internal strategy memos (founder analysis, roadmap drafting)
packages/slopbrick/docs/strategy-2026.md
packages/slopbrick/docs/strategy/

# Internal research notes — calibration, plan drafts, status reports.
# These are useful to the maintainer during the v0.x development
# cycle but are not part of the public docs surface.
packages/slopbrick/docs/research/

# Internal distribution / packaging notes
packages/slopbrick/distribute/README.md

# External corpus repos — cloned into the repo root for slopbrick
# calibration work, but they are full third-party checkouts (each
# has its own .git/, node_modules/, build artifacts). Not part of
# the usebrick codebase. Add to .gitignore to prevent accidental
# `git add -A` from committing ~1.4 GB of third-party code.
research/
.research/
automatic1111/
chatglm/
comfyui/
elevenlabs-js/
elevenlabs-python/
fastchat/
fooocus/
gpt-academic/
gradio/
helix/
llama-index2/
lmnr/
mastra/
oobabooga/
supabase/
vercel-ai/
